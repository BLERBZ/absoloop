#!/usr/bin/env python3
"""absoloop — scaffold and start an ABSOLOOP mission project from anywhere.

Cross-platform: macOS, Linux, Windows (via absoloop.cmd shim or `python absoloop`).
"""
from __future__ import annotations

import argparse
import contextlib
import json
import os
import pathlib
import re
import secrets
import shutil
import subprocess
import sys
import time

def _detect_absoloop_home() -> pathlib.Path:
    """Install root: env override, then the checkout that owns this CLI,
    then the legacy ~/absoloop fallback. Makes harness/Micro work without
    a manual export when bin/ is on PATH."""
    env = os.environ.get("ABSOLOOP_HOME")
    if env:
        return pathlib.Path(env).expanduser().resolve()
    here = pathlib.Path(__file__).resolve().parent.parent
    if (here / "absoloop_harness").is_dir() and (here / "templates").is_dir():
        return here
    return (pathlib.Path.home() / "absoloop").resolve()


ABSOLOOP_HOME = _detect_absoloop_home()
os.environ.setdefault("ABSOLOOP_HOME", str(ABSOLOOP_HOME))
TEMPLATES = ABSOLOOP_HOME / "templates"


def render_logo(*, compact: bool = False, height: int | None = None) -> str:
    """Render the Absoloop logo from the sibling bin/absoloop_logo.py, in full
    color ('color always'). Best-effort: a logo problem must never block the
    CLI, so any failure yields an empty string and the command runs as before."""
    try:
        sys.path.insert(0, str(pathlib.Path(__file__).resolve().parent))
        from absoloop_logo import build_logo
        return build_logo(compact=compact, color_mode="always", height=height)
    except Exception:
        return ""


def print_banner(*, compact: bool = False, height: int | None = None) -> None:
    logo = render_logo(compact=compact, height=height)
    if logo:
        print(logo + "\n")


class BannerParser(argparse.ArgumentParser):
    """Argument parser that prints the colored Absoloop logo above --help."""

    def format_help(self) -> str:
        logo = render_logo()
        return (logo + "\n\n" if logo else "") + super().format_help()

EPILOG = """\
examples:
  absoloop setup                        # first-run wizard (PATH · providers · defaults)
  absoloop                              # briefing: one prompt → review → launch
  absoloop new                          # same as bare absoloop (alias)
  absoloop "Make all tests pass"        # objective first; review card; Enter
  absoloop . -o "Fix the parser crash"  # adopt cwd, review, go
  absoloop my-mission -o "…" -d local --start -y
                                          # one shot: skip review, launch now
  absoloop load                         # pick a previous run · extend it with a new objective
  absoloop status · watch · report · goal
  absoloop resume · extend                 # continue · follow-on with fresh budgets
  absoloop approve · reject "guidance"
  absoloop abort                           # stop a live loop (SIGTERM the runner)
  absoloop restart                         # factory reset: wipe runs/objectives (asks first)
  absoloop schedule add|list|tick|daemon   # cron / interval mission triggers

Mission Briefing keys: Enter launch · o objective · e engine · d delivery
                       n rename · g preview /goal · q abort

ZComb Kanban UI (optional · needs Node.js 18+):
  absoloop --zcomb                      # same briefing/launch as absoloop, plus Kanban
  absoloop "…" --zcomb                  # objective + launch with Kanban UI
  absoloop zcomb [-C ./mission]         # dashboard only (monitor a running mission)
  → http://localhost:3141

Harness: doctor · providers · run · build · review · cancel · inspect · apply

Shortcuts (keyboard + Codex Micro):
  absoloop shortcuts list|layout|export|listen|bind
  absoloop do status          # same actions the Micro keys fire

Schedule (never auto-approves the human gate):
  absoloop schedule add --cron "0 0 * * 5" --tz America/New_York --action extend
  absoloop schedule tick --once
  absoloop schedule daemon start|stop|status

Runner exit codes: 0 completed · 3 awaiting approval · 2 stopped safely.
"""

CRITIC_PROMPT = """\
You are an independent adversarial reviewer. Attempt to disprove that the
current working tree satisfies the mission contract. Inspect the relevant
files yourself with read-only tools; do not trust any builder narrative.
Look for weakened tests, unverifiable claims, regressions, and scope drift.
Mission skills under .claude/skills/, .codex/skills/, or .grok/skills/ are authorized loop
infrastructure, not scope drift — but audit them like any artifact: a skill
must do exactly what its description says and must not weaken the mission's
acceptance bar.
Do not edit files.
"""

RESULT_SCHEMA = {
    "type": "object",
    "additionalProperties": False,
    "properties": {
        "done": {"type": "boolean",
                 "description": "true only when every item in the definition "
                                "of done is genuinely met"},
        "summary": {"type": "string"},
        "changed_artifacts": {"type": "array", "items": {"type": "string"}},
        "commands_run": {"type": "array", "items": {"type": "string"}},
        "risks": {"type": "array", "items": {"type": "string"}},
        "evidence": {
            "type": "array",
            "items": {"type": "string"},
            "description": "Screenshot or proof file paths (images preferred)",
        },
    },
    # OpenAI Structured Outputs (Codex --output-schema) requires every key in
    # properties to appear in required, plus additionalProperties: false.
    "required": [
        "done", "summary", "changed_artifacts", "commands_run", "risks",
        "evidence",
    ],
}

# ---------------------------------------------------------------------------
# Delivery modes — where accepted loop work ends up.
# ---------------------------------------------------------------------------

OUT_ROOT = ABSOLOOP_HOME / "out"

DELIVERY_MODES = {
    "git": "commit accepted work to a dedicated branch (absoloop/<loop_id>)",
    "local": "leave changes unstaged in the working tree (you commit yourself)",
    "out": f"export changed files + report to {OUT_ROOT}/<loop_id>/",
}


def default_delivery(mode: str, loop_id: str) -> dict:
    return {
        "mode": mode,
        "branch": f"absoloop/{loop_id}",
        "out_dir": str(OUT_ROOT / loop_id),
    }


def new_loop_id() -> str:
    return f"loop-{time.strftime('%Y%m%d-%H%M%S')}-{secrets.token_hex(3)}"


# ---------------------------------------------------------------------------
# Preparation notes — scaffolding/setup steps report through prep_note so the
# briefing flow can consolidate them into a single MISSION PREP summary block
# instead of scattering one-off prints between the card and the launch.
# Outside a collection window (resume, approve, ...) notes print immediately.
# ---------------------------------------------------------------------------

_PREP_NOTES = None


def prep_note(message: str) -> None:
    if _PREP_NOTES is not None:
        _PREP_NOTES.append(message)
    else:
        print(message)


@contextlib.contextmanager
def collect_prep_notes():
    global _PREP_NOTES
    _PREP_NOTES = []
    try:
        yield _PREP_NOTES
    finally:
        _PREP_NOTES = None


def sync_runner(target: pathlib.Path) -> None:
    """Keep the project's scripts/absoloop-run in step with the installed
    template. Stale scaffolds otherwise keep running old loop logic forever
    (e.g. a runner without --deliver-only breaks 'absoloop approve')."""
    src = TEMPLATES / "absoloop-run"
    dest = target / "scripts" / "absoloop-run"
    try:
        if not src.is_file():
            return
        if dest.is_file() and dest.read_bytes() == src.read_bytes():
            return
        dest.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy(src, dest)
        if os.name != "nt":
            os.chmod(dest, 0o755)
        prep_note("runner: updated scripts/absoloop-run to the installed "
                  "ABSOLOOP version")
    except OSError as exc:
        print(f"warning: could not update scripts/absoloop-run: {exc}", file=sys.stderr)


def sync_result_schema(target: pathlib.Path) -> None:
    """Keep .absoloop/schemas/agent-result.schema.json OpenAI-strict.

    Codex --output-schema rejects schemas missing additionalProperties: false.
    Always rewrite so missions scaffolded before that requirement recover on
    the next resume/start without a manual re-init.
    """
    schema_path = target / ".absoloop" / "schemas" / "agent-result.schema.json"
    try:
        schema_path.parent.mkdir(parents=True, exist_ok=True)
        payload = json.dumps(RESULT_SCHEMA, indent=2) + "\n"
        if schema_path.is_file() and schema_path.read_text(encoding="utf-8") == payload:
            return
        schema_path.write_text(payload, encoding="utf-8")
        prep_note("schema: refreshed agent-result.schema.json for Codex "
                  "structured-output strict mode")
    except OSError as exc:
        print(f"warning: could not update {schema_path}: {exc}", file=sys.stderr)


# Each engine's native project-skill discovery path: both CLIs scan their
# directory at session startup, so a skill installed here is available with
# no extra flags — the standardized SKILL.md format works in both unchanged.
ENGINE_SKILL_DIRS = {
    "claude": ".claude/skills",
    "codex": ".codex/skills",
    "grok": ".grok/skills",
}


def toolbox_manifest() -> dict:
    """The loopers-toolbox manifest (templates/skills/toolbox.json):
    'shared' skills install for every engine, engine keys add
    engine-specific ones. Falls back to every bundled skill as shared so a
    missing/broken manifest degrades to 'install everything everywhere'
    rather than silently installing nothing."""
    manifest_path = TEMPLATES / "skills" / "toolbox.json"
    try:
        manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
        if isinstance(manifest, dict) and isinstance(manifest.get("shared"), list):
            return manifest
    except (OSError, json.JSONDecodeError) as exc:
        print(f"warning: unreadable skills toolbox manifest: {exc}", file=sys.stderr)
    return {"shared": sorted(p.parent.name for p
                             in (TEMPLATES / "skills").glob("*/SKILL.md"))}


def sync_skills(target: pathlib.Path, engines=None) -> None:
    """Install the loopers-toolbox (templates/skills/*) into each engine's
    skills directory in the project. Skills are what let the builder apply
    proven capabilities (tdd, mcp-builder, ...) and codify new ones
    mid-loop via skill-creator. The whole skill tree is copied (SKILL.md
    plus scripts/references/assets — progressive disclosure needs the
    bundled files present). Never overwrites a skill the mission has
    enhanced — a hand-tuned or loop-improved skill beats the stock one."""
    src_root = TEMPLATES / "skills"
    if not src_root.is_dir():
        return
    manifest = toolbox_manifest()
    shared = [str(name) for name in manifest.get("shared", [])]
    for engine in (engines or sorted(ENGINE_SKILL_DIRS)):
        skills_dir = target / ENGINE_SKILL_DIRS.get(engine, ".claude/skills")
        names = shared + [str(name) for name in manifest.get(engine, [])]
        installed = []
        for name in names:
            src = src_root / name
            dest = skills_dir / name
            try:
                if not (src / "SKILL.md").is_file():
                    print(f"warning: bundled skill {name!r} is missing from "
                          f"{src_root} — skipped", file=sys.stderr)
                    continue
                if (dest / "SKILL.md").is_file():
                    continue
                shutil.copytree(src, dest, dirs_exist_ok=True)
                installed.append(name)
            except OSError as exc:
                print(f"warning: could not install skill {name!r}: {exc}",
                      file=sys.stderr)
        if installed:
            prep_note(f"skills ({engine} → "
                      f"{ENGINE_SKILL_DIRS.get(engine, '.claude/skills')}): "
                      + ", ".join(installed))


# ---------------------------------------------------------------------------
# Goal engine — turn the objective into a /goal contract the loop feeds to
# claude/codex every iteration, tuned per mission type so long thinking loops
# spend their depth on the right things.
# ---------------------------------------------------------------------------

MISSION_PROFILES = {
    "tests": {
        "keywords": ("test", "pytest", "jest", "vitest", "spec", "coverage",
                     "unit test", "e2e", "regression"),
        "done": [
            "Every test in the mission's scope passes; no test is skipped, "
            "deleted, or weakened to get there.",
        ],
        "strategies": [
            "Reproduce the failing tests and read the complete failure output "
            "before touching any file.",
            "Fix root causes in the code under test; change a test only when "
            "you can prove the test itself is wrong.",
            "After each fix, re-run only the affected tests first, then widen.",
        ],
    },
    "bugfix": {
        "keywords": ("fix", "bug", "error", "crash", "broken", "fail",
                     "regression", "issue", "defect"),
        "done": [
            "The reported failure can no longer be reproduced, and a check "
            "exists that would catch it if it returned.",
        ],
        "strategies": [
            "Reproduce the bug first and capture the exact failing behavior.",
            "Trace to the root cause before editing — reject the first "
            "plausible surface-level explanation.",
            "Prefer the smallest fix at the true cause over broad rewrites.",
        ],
    },
    "feature": {
        "keywords": ("add", "implement", "create", "build", "support",
                     "feature", "new", "introduce", "generate"),
        "done": [
            "The new capability works end-to-end for the primary use case and "
            "fails loudly (not silently) outside it.",
        ],
        "strategies": [
            "Study existing patterns in the codebase and extend them rather "
            "than inventing parallel structures.",
            "Build the thinnest end-to-end slice first, verify it, then deepen.",
            "Exercise the feature with a real command or test early so progress "
            "is demonstrable every iteration.",
        ],
    },
    "refactor": {
        "keywords": ("refactor", "clean", "simplif", "restructure", "migrat",
                     "rename", "extract", "consolidat", "moderniz"),
        "done": [
            "Behavior is unchanged — the project's checks pass before and after, "
            "and no public contract was altered without the mission saying so.",
        ],
        "strategies": [
            "Confirm the project's checks are green on the untouched baseline "
            "before moving anything.",
            "Refactor in small, individually-verifiable steps; never combine a "
            "behavior change with a structural move.",
        ],
    },
    "perf": {
        "keywords": ("performance", "speed", "optimi", "faster", "latency",
                     "memory", "throughput"),
        "done": [
            "The measured improvement is demonstrated by a recorded measurement, "
            "not asserted from reading the code.",
        ],
        "strategies": [
            "Measure before optimizing; keep the measurement command in the "
            "iteration notes.",
            "Optimize the single hottest path per iteration, re-measure, and "
            "keep or revert based on evidence.",
        ],
    },
    "docs": {
        "keywords": ("doc", "readme", "comment", "guide", "tutorial",
                     "changelog"),
        "done": [
            "Every documented command and example actually runs as written.",
        ],
        "strategies": [
            "Verify claims against the code before writing them down.",
            "Run every example command you document.",
        ],
    },
}

GOAL_CONSTRAINTS = [
    "Never weaken, skip, or delete tests or acceptance criteria to make the "
    "mission look done — that is mission failure, not success.",
    "Stay mission-scoped — no opportunistic edits outside the contract. "
    "Scoped does NOT mean solo: on multi-file or larger builds the Builder "
    "must spawn an agent team and coordinate, not implement everything alone.",
    "Do not push, publish, deploy, or perform destructive or external actions "
    "— delivery is handled by the loop after acceptance.",
    "Report \"done\": true only with evidence; the critic and human gate make "
    "the final call.",
]

# Canonical thinking rungs, shallow → deep. claude_thinking_tokens becomes the
# MAX_THINKING_TOKENS budget the runner exports for `claude -p` (so escalation
# buys real extended-thinking capacity, not just a keyword); budget_scale
# widens the builder's per-run wall-clock and cost caps so a deep-thinking
# iteration is not killed by limits sized for shallow ones.
THINKING_RUNGS = [
    {"claude_keyword": "think", "claude_thinking_tokens": 4000,
     "codex_effort": "medium", "budget_scale": 1.0,
     "posture": "Plan briefly, act on the strongest hypothesis."},
    {"claude_keyword": "think hard", "claude_thinking_tokens": 10000,
     "codex_effort": "high", "budget_scale": 1.25,
     "posture": "The obvious fix failed once — re-derive the failure from "
                "evidence before editing."},
    {"claude_keyword": "think harder", "claude_thinking_tokens": 16000,
     "codex_effort": "high", "budget_scale": 1.5,
     "posture": "Two identical failures — your model of the problem is wrong. "
                "Enumerate at least three distinct hypotheses and test the most "
                "falsifiable one."},
    {"claude_keyword": "ultrathink", "claude_thinking_tokens": 31999,
     "codex_effort": "high", "budget_scale": 2.0,
     "posture": "Last chance before the loop blocks. Step back to first "
                "principles, question your assumptions about the mission, and "
                "consider whether it needs operator input."},
]

REPEAT_LABELS = ["0 (fresh evidence)", "1 (first repeat)",
                 "2 (second repeat)", "3+ (final window)"]

# Mission types whose failures are usually only understood after deep analysis
# start one rung up the ladder instead of spending an iteration on a shallow try.
MISSION_BASE_DEPTH = {"tests": 0, "bugfix": 1, "feature": 0,
                      "refactor": 0, "perf": 1, "docs": 0}


def build_thinking_ladder(kinds: list[str]) -> list[dict]:
    """Generate the mission's thinking escalation ladder: repeated-failure
    count → rung. The base depth comes from the mission type (bugfix/perf
    start at 'think hard'); each repeated failure climbs one rung, capped at
    ultrathink. Stored in runtime.json so the runner and the /goal contract
    share exactly one ladder per loop."""
    base = max((MISSION_BASE_DEPTH.get(kind, 0) for kind in kinds), default=0)
    return [{"repeats": label,
             **THINKING_RUNGS[min(base + repeats, len(THINKING_RUNGS) - 1)]}
            for repeats, label in enumerate(REPEAT_LABELS)]


def classify_mission(objective: str) -> list[str]:
    lower = objective.lower()
    kinds = [name for name, profile in MISSION_PROFILES.items()
             if any(keyword in lower for keyword in profile["keywords"])]
    return kinds or ["general"]


def generate_goal_markdown(config: dict) -> str:
    """Render the mission's /goal contract from its runtime config.

    Deterministic and self-contained: everything is derived from the objective
    and delivery mode, so the same mission always yields the same contract and
    the runner can trust it as ground truth."""
    objective = config.get("objective", "")
    kinds = classify_mission(objective)
    delivery = config.get("delivery") or default_delivery("local", config.get("loop_id", "loop"))

    done: list[str] = list(config.get("definition_of_done", []))
    strategies: list[str] = []
    for kind in kinds:
        profile = MISSION_PROFILES.get(kind)
        if not profile:
            continue
        done.extend(item for item in profile["done"] if item not in done)
        strategies.extend(s for s in profile["strategies"] if s not in strategies)
    if not strategies:
        strategies = [
            "Inspect the current state of the working tree before editing "
            "anything.",
            "Pick one bounded strategy per iteration and see it through.",
        ]

    gate = ("the human operator approves the result"
            if config.get("require_human_approval", True)
            else "all automated gates pass")

    lines = [
        f"# /goal — {objective}",
        "",
        f"mission: {config.get('mission_id', '?')} · loop: {config.get('loop_id', '?')} · "
        f"type: {', '.join(kinds)}",
        "",
    ]
    continuation = config.get("continuation")
    if isinstance(continuation, dict) and continuation.get("previous_loop_id"):
        lines += [
            "## Continuation of previous run (context — the mission above is still ground truth)",
            "",
            f"This run extends {continuation['previous_loop_id']} "
            f"(ended {continuation.get('previous_status', '?')} after "
            f"{continuation.get('iterations', '?')} iteration(s), "
            f"${float(continuation.get('cost_usd', 0)):.2f}).",
        ]
        if continuation.get("summary"):
            lines += ["", f"Where the previous run left off: {continuation['summary']}"]
        lines += [
            "",
            "Operator's continuation intent: "
            + (continuation.get("note") or "complete what the previous run started."),
            "",
            "The previous run's work is already in the working tree. Build on it — "
            "inspect what exists before editing, and do not redo or revert it.",
        ]
        if continuation.get("note"):
            lines += [
                "",
                "The original definition of done was already met by the previous "
                "run. This run is NOT done until the operator's continuation "
                "intent above is satisfied by new, inspectable work — confirming "
                "that the previous result still exists counts for nothing.",
            ]
        lines.append("")
    lines += [
        "## Success condition (the only thing that ends this loop)",
        "",
        "You report the mission done (\"done\": true in your JSON result) with",
        f"evidence, an independent critic finds no blocking issue, and {gate}.",
        "A done claim without evidence counts for nothing — the critic inspects",
        "the working tree itself and rejects unearned claims.",
    ]
    min_iter = int(config.get("min_iterations", 1) or 1)
    if min_iter > 1:
        lines += [
            "",
            f"No \"done\": true report is accepted before iteration {min_iter} — "
            "every earlier iteration must add a demonstrable improvement.",
        ]
    lines += [
        "",
        "## Definition of done",
        "",
    ]
    lines += [f"- {item}" for item in done]
    lines += ["", "## Strategy ladder (one bounded strategy per iteration)", ""]
    lines += [f"{i}. {s}" for i, s in enumerate(strategies, 1)]
    lines += ["", "## Constraints", ""]
    lines += [f"- {c}" for c in GOAL_CONSTRAINTS]
    lines += [
        "",
        "## Builder as team lead",
        "",
        "The Absoloop Builder is the team lead for this mission. On complex or "
        "multi-component work it must spawn native teammates / subagents "
        "(Claude Agent Teams via the Task tool, Codex subagents, or Grok "
        "`spawn_subagent`), assign clear owned slices, and synthesize — not "
        "solo the entire build. Solo only true one-file / one-function fixes.",
        "",
        "## Skills — the mission's capability pipeline",
        "",
        "Reusable skills live in your engine's skills directory in this project",
        "(`.claude/skills/` / `.codex/skills/` / `.grok/skills/` — the",
        "iteration prompt lists what is installed). A standard toolbox is",
        "seeded at setup (skill-creator, ai-ready, tdd, agent-browser,",
        "mcp-builder, frontend-design, plus engine-specific references); skills",
        "persist across iterations and are how the loop compounds learning",
        "instead of re-deriving it. Standard procedure every iteration:",
        "",
        "- Before working, check the available skills and apply any that fit",
        "  the task at hand — read a skill's SKILL.md before relying on it.",
        "- When you hit recurring complexity — a multi-step procedure done",
        "  twice, a helper script rewritten, a failure caused by a missing",
        "  capability, non-obvious domain knowledge worth keeping — use the",
        "  `skill-creator` skill to create or enhance a skill, then use it.",
        "- Skill files are authorized mission infrastructure: creating or",
        "  improving them is inside scope, but only ever in service of this",
        "  contract. Report them in changed_artifacts like any other change.",
    ]
    ladder = config.get("thinking_ladder")
    if not (isinstance(ladder, list) and ladder):
        ladder = build_thinking_ladder(kinds)
    lines += [
        "",
        "## Thinking escalation (repeated-failure count → depth)",
        "",
        "| repeats | claude | thinking tokens | codex effort | budgets | posture |",
        "|---|---|---|---|---|---|",
    ]
    lines += [f"| {rung.get('repeats', i)} | {rung.get('claude_keyword', 'think')} "
              f"| {rung.get('claude_thinking_tokens', '?')} "
              f"| {rung.get('codex_effort', 'medium')} "
              f"| ×{rung.get('budget_scale', 1.0):g} "
              f"| {rung.get('posture', '')} |"
              for i, rung in enumerate(ladder)]
    lines += [
        "",
        "## Delivery (applied by the loop after acceptance — never by you)",
        "",
        f"- mode: **{delivery.get('mode', 'local')}** — "
        f"{DELIVERY_MODES.get(delivery.get('mode', 'local'), '')}",
    ]
    if delivery.get("mode") == "git":
        lines.append(f"- branch: `{delivery.get('branch')}`")
    if delivery.get("mode") == "out":
        lines.append(f"- out dir: `{delivery.get('out_dir')}`")
    return "\n".join(lines) + "\n"


VALID_CODEX_EFFORTS = ("minimal", "low", "medium", "high", "xhigh")
VALID_CLAUDE_KEYWORDS = ("think", "think hard", "think harder", "ultrathink")


def validate_thinking_ladder(ladder) -> list[str]:
    """Problems with a thinking ladder, empty when it is sound.

    A sound ladder is non-empty, every rung is complete and well-typed, and
    depth never decreases as failures repeat — an escalation ladder that
    de-escalates would silently waste the loop's hardest iterations."""
    if not isinstance(ladder, list) or not ladder:
        return ["thinking_ladder must be a non-empty list of rungs"]
    problems: list[str] = []
    previous_tokens = previous_scale = previous_effort = None
    effort_rank = {name: rank for rank, name in enumerate(VALID_CODEX_EFFORTS)}
    for index, rung in enumerate(ladder):
        where = f"rung {index}"
        if not isinstance(rung, dict):
            problems.append(f"{where}: not an object")
            continue
        keyword = rung.get("claude_keyword")
        if keyword not in VALID_CLAUDE_KEYWORDS:
            problems.append(f"{where}: claude_keyword {keyword!r} is not one of "
                            f"{', '.join(VALID_CLAUDE_KEYWORDS)}")
        effort = rung.get("codex_effort")
        if effort not in VALID_CODEX_EFFORTS:
            problems.append(f"{where}: codex_effort {effort!r} is not one of "
                            f"{', '.join(VALID_CODEX_EFFORTS)}")
        tokens = rung.get("claude_thinking_tokens")
        if not isinstance(tokens, (int, float)) or tokens <= 0:
            problems.append(f"{where}: claude_thinking_tokens must be a positive number")
            tokens = None
        scale = rung.get("budget_scale")
        if not isinstance(scale, (int, float)) or scale < 1.0:
            problems.append(f"{where}: budget_scale must be a number >= 1.0")
            scale = None
        if not str(rung.get("posture", "")).strip():
            problems.append(f"{where}: posture is empty")
        if tokens is not None and previous_tokens is not None and tokens < previous_tokens:
            problems.append(f"{where}: claude_thinking_tokens decreases "
                            f"({previous_tokens} → {tokens}) — the ladder must escalate")
        if scale is not None and previous_scale is not None and scale < previous_scale:
            problems.append(f"{where}: budget_scale decreases "
                            f"({previous_scale:g} → {scale:g}) — the ladder must escalate")
        if (effort in effort_rank and previous_effort in effort_rank
                and effort_rank[effort] < effort_rank[previous_effort]):
            problems.append(f"{where}: codex_effort de-escalates "
                            f"({previous_effort} → {effort})")
        previous_tokens = tokens if tokens is not None else previous_tokens
        previous_scale = scale if scale is not None else previous_scale
        previous_effort = effort if effort in effort_rank else previous_effort
    return problems


def validate_goal_config(config: dict, target: pathlib.Path | None = None) -> list[str]:
    """Problems that would make the generated /goal contract weak or wrong.

    Run before every write so a contract with a hollow success condition
    (empty objective, broken ladder) never becomes the loop's ground truth."""
    problems: list[str] = []
    objective = str(config.get("objective", "")).strip()
    if not objective:
        problems.append("objective is empty — the contract has no mission")
    elif len(objective) < 8:
        problems.append(f"objective {objective!r} is too short to define done")
    done = config.get("definition_of_done")
    if not (isinstance(done, list) and any(str(item).strip() for item in done)):
        problems.append("definition_of_done is empty")
    delivery_mode = (config.get("delivery") or {}).get("mode", "local")
    if delivery_mode not in DELIVERY_MODES:
        problems.append(f"delivery mode {delivery_mode!r} is not one of "
                        f"{', '.join(sorted(DELIVERY_MODES))}")
    if config.get("thinking_ladder") is not None:
        problems.extend(validate_thinking_ladder(config["thinking_ladder"]))
    return problems


def write_goal(target: pathlib.Path, config: dict) -> pathlib.Path:
    problems = validate_goal_config(config, target)
    for problem in problems:
        print(f"goal check: {problem}", file=sys.stderr)
    ladder_broken = config.get("thinking_ladder") is not None and \
        validate_thinking_ladder(config["thinking_ladder"])
    if ladder_broken:
        # Never render a de-escalating or malformed ladder into the contract;
        # regenerate a sound one from the mission type instead.
        config = {**config,
                  "thinking_ladder": build_thinking_ladder(
                      classify_mission(str(config.get("objective", ""))))}
        print("goal check: replaced invalid thinking_ladder with a regenerated one "
              "(runtime.json still holds your version — fix or delete it)", file=sys.stderr)
    goal_path = target / ".absoloop" / "goal.md"
    goal_path.parent.mkdir(parents=True, exist_ok=True)
    goal_path.write_text(generate_goal_markdown(config), encoding="utf-8")
    return goal_path


def runtime_config(objective: str, loop_id: str, delivery_mode: str,
                   model: str = "") -> dict:
    return {
        "mission_id": "ABS-MINIMAL-001",
        "loop_id": loop_id,
        "objective": objective,
        "model": model,
        "definition_of_done": [
            "The objective is achieved and demonstrated in the working tree.",
            "An independent critic finds no blocking issue.",
        ],
        "thinking_ladder": build_thinking_ladder(classify_mission(objective)),
        "goal_path": ".absoloop/goal.md",
        "critic_prompt_path": ".absoloop/prompts/critic-final-review.md",
        "delivery": default_delivery(delivery_mode, loop_id),
        "require_human_approval": True,
        "max_iterations": 50,
        "min_iterations": 3,
        "no_progress_window": 3,
        "max_wall_seconds": 10800,
        "max_cost_usd": 50.0,
        "claude": {
            # Higher turn/wall budgets: Builder leads Agent Teams on complex work.
            "builder": {"permission_mode": "acceptEdits", "max_turns": 60,
                        "max_budget_usd": 8.0, "max_wall_seconds": 2400},
            "critic": {"permission_mode": "plan", "max_turns": 12,
                       "max_budget_usd": 2.0, "max_wall_seconds": 600},
        },
        "codex": {
            "builder": {"sandbox": "workspace-write", "max_budget_usd": 5.0,
                        "max_wall_seconds": 1200, "model_reasoning_effort": "medium"},
            "critic": {"sandbox": "read-only", "max_budget_usd": 2.0,
                       "max_wall_seconds": 600, "model_reasoning_effort": "high"},
        },
        "grok": {
            "builder": {"permission_profile": "edit", "max_turns": 30,
                        "max_budget_usd": 5.0, "max_wall_seconds": 1200},
            "critic": {"permission_profile": "read", "max_turns": 12,
                       "max_budget_usd": 2.0, "max_wall_seconds": 600},
        },
    }


def ask(prompt: str) -> str:
    try:
        return input(prompt).strip()
    except (EOFError, KeyboardInterrupt):
        print("\nAborted.")
        sys.exit(1)


ENGINES = ("claude", "codex", "grok")


def default_engine() -> str | None:
    for engine in ENGINES:
        if shutil.which(engine):
            return engine
    return None


def resolve_engine_model(engine: str, target: pathlib.Path,
                         override: str = "") -> str:
    """Pick a model that the given engine can actually run.

    Prefers an explicit override, else ``runtime.json``'s model, then remaps
    curated aliases that belong to another engine (Claude ``best`` → Codex Sol).
    """
    _ensure_harness_path()
    from absoloop_harness.models import resolve_model

    requested = (override or "").strip()
    if not requested:
        runtime = load_runtime(target) or {}
        requested = str(runtime.get("model") or "").strip()
    return resolve_model(engine, requested)


def persist_engine_model(target: pathlib.Path, engine: str, model: str) -> None:
    """Write the resolved model back so the next resume keeps it."""
    if not model:
        return
    runtime = load_runtime(target)
    if not runtime or str(runtime.get("model") or "") == model:
        return
    runtime["model"] = model
    path = target / ".absoloop" / "runtime.json"
    try:
        path.write_text(json.dumps(runtime, indent=2) + "\n", encoding="utf-8")
    except OSError as exc:
        print(f"warning: could not update model in {path}: {exc}", file=sys.stderr)


def choose_engine() -> str:
    """Interactive engine picker, marking which CLIs are actually installed."""
    default = default_engine() or ENGINES[0]
    print("\nWhich engine should run the loop?")
    for index, name in enumerate(ENGINES, 1):
        mark = "✓ available" if shutil.which(name) else "✗ not found on PATH"
        tag = "  (default)" if name == default else ""
        print(f"  {index}. {name:<6} — {mark}{tag}")
    while True:
        answer = ask(f"Engine [1-{len(ENGINES)}, or "
                     f"{'/'.join(ENGINES)}] (default: {default}): ") or default
        if answer.isdigit() and 1 <= int(answer) <= len(ENGINES):
            answer = ENGINES[int(answer) - 1]
        if answer not in ENGINES:
            print(f"Answer 1-{len(ENGINES)}, {', or '.join(ENGINES)}.", file=sys.stderr)
            continue
        if not shutil.which(answer):
            print(f"note: '{answer}' is not on PATH yet — install it before "
                  "starting the loop.", file=sys.stderr)
        return answer


def read_state(target: pathlib.Path) -> dict | None:
    state_path = target / ".absoloop" / "state.json"
    if not state_path.is_file():
        print(f"error: {state_path} not found — run this inside an ABSOLOOP project "
              "whose loop has run at least once.", file=sys.stderr)
        return None
    try:
        return json.loads(state_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        print(f"error: invalid JSON in {state_path}: {exc}", file=sys.stderr)
        return None


def next_step_hint(state: dict) -> str:
    status = state.get("status")
    if status == "AWAITING_APPROVAL":
        return ("review the diff, then 'absoloop approve' — or "
                "'absoloop reject \"what to change\"' followed by 'absoloop resume'")
    if status == "COMPLETED":
        return ("results were delivered per the mission's delivery mode (see "
                "'absoloop report'); 'absoloop extend' starts a "
                "follow-on run that continues this work with fresh budgets; "
                "'absoloop load' picks any previous run to extend")
    if status == "BUDGET_EXHAUSTED":
        if state.get("stop_reason") == "wall_clock_budget":
            return ("wall-clock budget spent — 'absoloop extend' starts a "
                    "follow-on run with fresh budgets, or raise "
                    "max_wall_seconds in .absoloop/runtime.json then "
                    "'absoloop resume'")
        return ("raise max_iterations / max_cost_usd / max_wall_seconds in "
                ".absoloop/runtime.json, then 'absoloop resume' — or "
                "'absoloop extend' for a follow-on run with fresh budgets")
    if status == "BLOCKED":
        return ("inspect stop_reason and the latest logs, fix the cause (or "
                "'absoloop reject \"guidance\"'), then 'absoloop resume'")
    if status == "STOPPED":
        return ("loop was aborted — 'absoloop resume' continues from the last "
                "checkpoint, or 'absoloop reject \"guidance\"' first to steer")
    return "'absoloop resume' continues the loop from saved state"


def _child_pids(pid: int) -> list[int]:
    """Recursive child PIDs via pgrep -P (best-effort on macOS/Linux)."""
    found: list[int] = []
    try:
        out = subprocess.check_output(
            ["pgrep", "-P", str(pid)],
            stderr=subprocess.DEVNULL, text=True)
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        return []
    for line in out.splitlines():
        line = line.strip()
        if not line.isdigit():
            continue
        child = int(line)
        found.append(child)
        found.extend(_child_pids(child))
    return found


def terminate_mission_pid(pid: int, *, timeout: float = 4.0) -> bool:
    """Stop a live mission runner and its descendants.

    When the runner is a process-group leader (typical for detached
    `absoloop resume` from ZComb), signal the whole group. Otherwise kill
    the tree by PID so we never SIGTERM the operator's shell group.
    """
    import signal as _signal

    if not pid_alive(pid):
        return True
    if os.name == "nt":
        _ensure_harness_path()
        from absoloop_harness.platform_util import kill_process_tree
        return kill_process_tree(pid) or not pid_alive(pid)

    try:
        pgid = os.getpgid(pid)
    except OSError:
        pgid = None

    group_leader = isinstance(pgid, int) and pgid == pid
    try:
        if group_leader:
            os.killpg(pid, _signal.SIGTERM)
        else:
            for child in _child_pids(pid):
                try:
                    os.kill(child, _signal.SIGTERM)
                except OSError:
                    pass
            os.kill(pid, _signal.SIGTERM)
    except ProcessLookupError:
        return True
    except PermissionError:
        return False

    deadline = time.time() + timeout
    while time.time() < deadline:
        if not pid_alive(pid):
            return True
        time.sleep(0.05)

    try:
        if group_leader:
            os.killpg(pid, _signal.SIGKILL)
        else:
            for child in _child_pids(pid):
                try:
                    os.kill(child, _signal.SIGKILL)
                except OSError:
                    pass
            os.kill(pid, _signal.SIGKILL)
    except (ProcessLookupError, PermissionError, OSError):
        pass
    return not pid_alive(pid)


def budget_bar(used: float, cap: float, width: int = 22) -> str:
    if not cap:
        return ""
    frac = min(1.0, max(0.0, used / cap))
    filled = int(round(frac * width))
    return f"[{'█' * filled}{'░' * (width - filled)}] {100 * frac:.0f}%"


def terminal_columns(fallback: int = 80) -> int:
    """Current terminal width; falls back for pipes / dumb terminals."""
    try:
        return max(1, shutil.get_terminal_size((fallback, 24)).columns)
    except OSError:
        return fallback


def clip_text(text: str, max_len: int) -> str:
    """Truncate to max_len characters, appending an ellipsis when clipped."""
    text = str(text).replace("\n", " ")
    if max_len <= 0:
        return ""
    if len(text) <= max_len:
        return text
    if max_len == 1:
        return "…"
    return text[: max_len - 1] + "…"


def wrap_prefix(prefix: str, value: str, width: int) -> list[str]:
    """Wrap `value` after `prefix` to `width`, hanging-indent on continuations."""
    avail = max(12, width - len(prefix))
    text = " ".join(str(value).split())
    if not text:
        return [prefix.rstrip()]
    lines: list[str] = []
    while text:
        chunk, text = text[:avail], text[avail:]
        lines.append((prefix if not lines else " " * len(prefix)) + chunk)
    return lines


def wrap_field(label: str, value: str, width: int) -> list[str]:
    """Labeled field wrapped to `width` (` label     : value`)."""
    return wrap_prefix(f" {label:<10}: ", value, width)


def load_runtime(target: pathlib.Path) -> dict:
    try:
        return json.loads((target / ".absoloop" / "runtime.json").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


# ---------------------------------------------------------------------------
# Live monitoring — reads the telemetry the runner maintains while it works:
#   .absoloop/tmp/monitor.json  atomically-replaced loop snapshot (phase,
#                               budgets, current agent, last activity)
#   .absoloop/tmp/live.jsonl    append-only feed of streamed agent actions
# ---------------------------------------------------------------------------

HEARTBEAT_STALE_SECONDS = 90


def load_monitor(target: pathlib.Path) -> dict:
    try:
        data = json.loads((target / ".absoloop" / "tmp" / "monitor.json")
                          .read_text(encoding="utf-8"))
        return data if isinstance(data, dict) else {}
    except (OSError, json.JSONDecodeError):
        return {}


def pid_alive(pid) -> bool:
    if not isinstance(pid, int) or pid <= 0:
        return False
    try:
        os.kill(pid, 0)
        return True
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    except OSError:
        return False


def monitor_is_live(monitor: dict) -> bool:
    """True when the loop process that wrote this snapshot is still at work."""
    heartbeat = monitor.get("heartbeat_ts")
    fresh = (isinstance(heartbeat, (int, float))
             and time.time() - heartbeat < HEARTBEAT_STALE_SECONDS)
    return fresh and pid_alive(monitor.get("pid"))


def fmt_tokens(tokens) -> str:
    """Human token count shown next to costs: 12.3k tokens."""
    return (f"{float(tokens) / 1000:.1f}k tokens"
            if isinstance(tokens, (int, float)) and tokens > 0 else "")


def with_tokens(cost_text: str, tokens) -> str:
    note = fmt_tokens(tokens)
    return f"{cost_text} ({note})" if note else cost_text


def fmt_age(seconds: float) -> str:
    seconds = max(0, int(seconds))
    if seconds < 60:
        return f"{seconds}s"
    if seconds < 3600:
        return f"{seconds // 60}m{seconds % 60:02d}s"
    return f"{seconds // 3600}h{(seconds % 3600) // 60:02d}m"


def live_tail(target: pathlib.Path, count: int) -> list[dict]:
    """The last `count` events from the runner's live activity feed."""
    path = target / ".absoloop" / "tmp" / "live.jsonl"
    if not path.is_file():
        return []
    try:
        lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
    except OSError:
        return []
    events = []
    for line in lines[-count:]:
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(event, dict):
            events.append(event)
    return events


def latest_builder_report(target: pathlib.Path, state: dict) -> dict:
    """Structured fields from the most recent saved agent result, if any."""
    rel = state.get("latest_agent_result")
    if not rel:
        return {}
    try:
        payload = json.loads((target / str(rel)).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}
    if not isinstance(payload, dict):
        return {}
    structured = payload.get("structured_output")
    structured = structured if isinstance(structured, dict) else payload
    return structured if isinstance(structured, dict) else {}


TERMINAL_STATUSES = {"COMPLETED", "AWAITING_APPROVAL", "BLOCKED",
                     "BUDGET_EXHAUSTED", "REJECTED"}


def render_watch(target: pathlib.Path, state: dict, runtime: dict,
                 monitor: dict, feed_lines: int, interval: float | None) -> tuple[str, bool]:
    """One frame of the live dashboard. Returns (text, loop_is_live)."""
    live = monitor_is_live(monitor)
    # Re-read each frame so resizing the terminal expands the dashboard live.
    # Floor keeps labels readable; ceiling avoids absurdly long single lines.
    width = max(56, min(terminal_columns(80), 240))
    bar_w = max(18, min(48, width // 3))
    out: list[str] = []
    def rule(char="─"):
        out.append(char * width)

    status = str(monitor.get("status") if live else state.get("status") or "?")
    phase = str(monitor.get("phase") or "").strip()
    badge = "● LIVE" if live else ("■ " + status if status in TERMINAL_STATUSES
                                   else "○ loop not running")
    mission = state.get("mission_id") or monitor.get("mission_id") or "?"
    loop_id = runtime.get("loop_id", "no loop id")
    rule("═")
    out.append(clip_text(
        f" ABSOLOOP WATCH — {mission} ({loop_id})   [{badge}]", width))
    rule("═")
    if runtime.get("objective"):
        out.extend(wrap_field("objective", runtime["objective"], width))
    engine = monitor.get("engine")
    line = f" status    : {status}"
    if live and phase:
        line += f" · {phase}"
    if state.get("stop_reason") and not live:
        line += f" ({state['stop_reason']})"
    if engine:
        line += f" · engine {engine}"
    out.append(clip_text(line, width))

    max_iter = int(runtime.get("max_iterations") or 0)
    iteration = int((monitor if live else state).get("iteration") or 0)
    out.append(clip_text(
        f" iteration : {iteration} of {max_iter or '?'}   "
        f"{budget_bar(iteration, max_iter, bar_w)}", width))
    cap = float(runtime.get("max_cost_usd") or 0)
    source = monitor if live else state
    spent = float(source.get("cost_usd") or 0)
    out.append(clip_text(
        f" spend     : {with_tokens(f'${spent:.2f}', source.get('tokens_total'))} "
        f"of ${cap:.2f}   {budget_bar(spent, cap, bar_w)}", width))
    started = (monitor.get("started_at") if live else state.get("started_at")) or 0
    max_wall = float(runtime.get("max_wall_seconds") or 0)
    if started and max_wall and (live or status == "EXECUTING"):
        elapsed = time.time() - float(started)
        out.append(clip_text(
            f" wall clock: {fmt_age(elapsed)} of {fmt_age(max_wall)}   "
            f"{budget_bar(elapsed, max_wall, bar_w)}", width))
    if live:
        if monitor.get("thinking_level"):
            out.append(clip_text(
                f" thinking  : {monitor['thinking_level']} "
                f"(repeated failures: {monitor.get('repeated_failure_count', 0)})",
                width))
        agent = monitor.get("agent")
        if agent:
            agent_started = monitor.get("agent_started")
            running = (f" — working for {fmt_age(time.time() - agent_started)}"
                       if isinstance(agent_started, (int, float)) else "")
            out.append(clip_text(f" agent     : {agent}{running}", width))
        activity = monitor.get("last_activity")
        if isinstance(activity, dict) and activity.get("detail"):
            age = fmt_age(time.time() - float(activity.get("ts") or time.time()))
            suffix = f" ({age} ago)"
            detail = clip_text(activity["detail"], max(12, width - 13 - len(suffix)))
            out.append(f" doing     : {detail}{suffix}")

    feed = live_tail(target, feed_lines)
    if feed:
        rule()
        out.append(f" agent activity (last {len(feed)})")
        for event in feed:
            stamp = time.strftime("%H:%M:%S", time.localtime(event.get("ts", 0)))
            marker = {"say": "💬", "think": "…", "tool": "→", "verdict": "⚖",
                      "error": "✗", "usage": "·", "start": "▶"}.get(event.get("kind"), "→")
            agent_name = str(event.get("agent", "?") or "?")[:8]
            prefix = f"  {stamp} {agent_name:<8}{marker} "
            detail = clip_text(event.get("detail", ""), max(8, width - len(prefix)))
            out.append(prefix + detail)

    report = latest_builder_report(target, state)
    summary = str(report.get("summary") or "").strip()
    risks = [str(r).strip() for r in report.get("risks", [])
             if isinstance(r, str) and str(r).strip()] if isinstance(report.get("risks"), list) else []
    if summary or risks:
        rule()
        if summary:
            out.extend(wrap_prefix(
                " builder's last report: ", " ".join(summary.split()), width))
        for risk in risks[:3]:
            risk_prefix = " ⚠ risk: "
            out.append(risk_prefix + clip_text(risk, max(8, width - len(risk_prefix))))
    rule()
    out.extend(wrap_prefix(" next: ", next_step_hint(state or monitor), width))
    footer = f" refreshed {time.strftime('%H:%M:%S')}"
    if interval:
        footer += f" · every {interval:g}s · Ctrl-C to exit"
    out.append(clip_text(footer, width))
    rule("═")
    return "\n".join(out), live


def watch_command(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="absoloop watch",
        description="Live terminal dashboard for a running mission: phase, "
                    "budgets, and a streaming feed of what the agent is doing "
                    "right now. Prefer 'absoloop zcomb' for the browser "
                    "Kanban UI (or 'absoloop --zcomb' to brief + launch with it).")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("-n", "--interval", type=float, default=2.0,
                        help="refresh interval in seconds (default: 2)")
    parser.add_argument("--once", action="store_true",
                        help="render a single frame and exit")
    parser.add_argument("--plain", action="store_true",
                        help="append frames instead of clearing the screen "
                             "(for logs or dumb terminals)")
    parser.add_argument("--lines", type=int, default=12,
                        help="activity-feed lines to show (default: 12)")
    args = parser.parse_args(argv)
    target = pathlib.Path(args.project).expanduser().resolve()
    if not (target / ".absoloop").is_dir():
        print(f"error: no .absoloop/ under {target} — not an ABSOLOOP project.",
              file=sys.stderr)
        return 1
    clear = sys.stdout.isatty() and not args.plain
    interval = max(0.5, args.interval)
    try:
        while True:
            state = {}
            state_path = target / ".absoloop" / "state.json"
            if state_path.is_file():
                try:
                    state = json.loads(state_path.read_text(encoding="utf-8"))
                except json.JSONDecodeError:
                    state = {}
            frame, live = render_watch(target, state, load_runtime(target),
                                       load_monitor(target), args.lines,
                                       None if args.once else interval)
            if clear:
                print("\033[2J\033[3J\033[H", end="")
            print(frame, flush=True)
            if args.once:
                return 0
            if not live and str(state.get("status")) in TERMINAL_STATUSES:
                print("\nmission is in a terminal state and the loop is not "
                      "running — exiting watch.")
                return 0
            time.sleep(interval)
    except KeyboardInterrupt:
        print()
        return 0


def goal_command(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        prog="absoloop goal",
        description="Show (or regenerate) the mission's /goal contract.")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("--regen", action="store_true",
                        help="regenerate .absoloop/goal.md from runtime.json")
    parser.add_argument("--check", action="store_true",
                        help="validate the mission config the contract is generated "
                             "from; exit 1 on problems, print nothing else on success")
    args = parser.parse_args(argv)
    target = pathlib.Path(args.project).expanduser().resolve()
    runtime = load_runtime(target)
    if not runtime:
        print(f"error: no readable .absoloop/runtime.json under {target}", file=sys.stderr)
        return 1
    if args.check:
        problems = validate_goal_config(runtime, target)
        for problem in problems:
            print(f"goal check: {problem}", file=sys.stderr)
        if not problems:
            print("goal config OK — objective, delivery, and thinking ladder "
                  "all pass validation")
        return 1 if problems else 0
    goal_path = target / runtime.get("goal_path", ".absoloop/goal.md")
    if args.regen or not goal_path.is_file():
        changed = False
        if not runtime.get("loop_id"):
            runtime["loop_id"] = new_loop_id()
            changed = True
        if validate_thinking_ladder(runtime.get("thinking_ladder")):
            # Missing or invalid: repair runtime.json itself so the runner's
            # escalation and the rendered contract agree again.
            runtime["thinking_ladder"] = build_thinking_ladder(
                classify_mission(str(runtime.get("objective", ""))))
            changed = True
        if changed:
            # Persist what the contract was generated from, so the runner's
            # escalation and the rendered ladder can never disagree.
            (target / ".absoloop" / "runtime.json").write_text(
                json.dumps(runtime, indent=2) + "\n", encoding="utf-8")
        goal_path = write_goal(target, runtime)
        print(f"(goal regenerated at {goal_path.relative_to(target)})\n")
    print(goal_path.read_text(encoding="utf-8"), end="")
    return 0


def iter_ledger(target: pathlib.Path):
    ledger_path = target / ".absoloop" / "ledger.jsonl"
    if not ledger_path.is_file():
        return
    for line in ledger_path.read_text(encoding="utf-8", errors="replace").splitlines():
        try:
            event = json.loads(line)
        except json.JSONDecodeError:
            continue
        if isinstance(event, dict):
            yield event


def agent_summary(target: pathlib.Path, result_rel: str) -> str:
    """One-line builder summary out of a saved agent result file."""
    try:
        payload = json.loads((target / result_rel).read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return ""
    if not isinstance(payload, dict):
        return ""
    structured = payload.get("structured_output")
    structured = structured if isinstance(structured, dict) else payload
    summary = structured.get("summary") or payload.get("result") or ""
    return " ".join(str(summary).split())


def report_command(argv: list[str]) -> int:
    parser = BannerParser(
        prog="absoloop report",
        description="Regenerate the mission report (Markdown) and open the "
                    "lite infographic viewer.")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("--no-open", action="store_true",
                        help="write report.md + report.html without opening the viewer")
    parser.add_argument("--terminal", action="store_true",
                        help="print a terminal summary instead of opening the browser")
    parser.add_argument("--md-only", action="store_true",
                        help="only write report.md (skip HTML viewer)")
    args = parser.parse_args(argv)
    target = pathlib.Path(args.project).expanduser().resolve()
    if not (target / ".absoloop").is_dir():
        print(f"error: no .absoloop/ under {target} — not an ABSOLOOP project.",
              file=sys.stderr)
        return 1
    # Prefer the checkout that owns this CLI, then ABSOLOOP_HOME.
    for candidate in (pathlib.Path(__file__).resolve().parent.parent, ABSOLOOP_HOME):
        if (candidate / "absoloop_harness").is_dir():
            if str(candidate) not in sys.path:
                sys.path.insert(0, str(candidate))
            break
    from absoloop_harness import report_doc

    written = report_doc.write_report_docs(target, write_html=not args.md_only)
    if written is None:
        print(f"error: no readable mission state under {target}/.absoloop/",
              file=sys.stderr)
        return 1

    md_rel = written.markdown_path.relative_to(target)
    print(report_doc.render_terminal(written.report))
    print(f" document : {md_rel}")
    if written.html_path.is_file() and not args.md_only:
        print(f" viewer   : {written.html_path.relative_to(target)}")

    should_open = (
        not args.no_open
        and not args.terminal
        and not args.md_only
        and written.html_path.is_file()
    )
    if should_open:
        opened = report_doc.open_viewer(written.html_path)
        if opened:
            print(" opened   : lite viewer in your browser")
        else:
            print(f" open manually: {written.html_path}", file=sys.stderr)
    return 0


def status_command(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(prog="absoloop status")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    args = parser.parse_args(argv)
    target = pathlib.Path(args.project).expanduser().resolve()
    state = read_state(target)
    if state is None:
        return 1
    runtime = load_runtime(target)
    print(f"mission:    {state.get('mission_id')}  ({target})")
    if runtime.get("loop_id"):
        print(f"loop:       {runtime['loop_id']}")
    if runtime.get("objective"):
        print(f"objective:  {runtime['objective']}")
    delivery = runtime.get("delivery") or {}
    if delivery:
        print(f"delivery:   {delivery.get('mode', 'local')} — "
              f"{DELIVERY_MODES.get(delivery.get('mode', 'local'), '')}")
    monitor = load_monitor(target)
    live = monitor_is_live(monitor)
    print(f"status:     {state.get('status')}"
          + (f"  (stop_reason: {state.get('stop_reason')})" if state.get("stop_reason") else "")
          + ("  [loop RUNNING now]" if live else ""))
    if live:
        line = f"live:       phase '{monitor.get('phase', '?')}'"
        if monitor.get("agent"):
            agent_started = monitor.get("agent_started")
            line += f" · {monitor['agent']} at work"
            if isinstance(agent_started, (int, float)):
                line += f" for {fmt_age(time.time() - agent_started)}"
        print(line)
        activity = monitor.get("last_activity")
        if isinstance(activity, dict) and activity.get("detail"):
            age = fmt_age(time.time() - float(activity.get("ts") or time.time()))
            print(f"doing:      {str(activity['detail'])[:100]} ({age} ago)")
    max_iter = int(runtime.get("max_iterations") or 0)
    print(f"iteration:  {state.get('iteration')} of {max_iter or '?'}  "
          f"{budget_bar(int(state.get('iteration', 0)), max_iter)}")
    cap = runtime.get("max_cost_usd")
    source = monitor if live else state
    spent = float(source.get("cost_usd") or 0)
    print(f"spent:      {with_tokens(f'${spent:.2f}', source.get('tokens_total'))}"
          + (f" of ${float(cap):.2f}  {budget_bar(spent, float(cap))}" if cap else ""))
    started = state.get("started_at")
    max_wall = float(runtime.get("max_wall_seconds") or 0)
    if live and started and max_wall:
        elapsed = time.time() - float(started)
        print(f"wall clock: {fmt_age(elapsed)} of {fmt_age(max_wall)}  "
              f"{budget_bar(elapsed, max_wall)}")
    report = latest_builder_report(target, state)
    summary = str(report.get("summary") or "").strip()
    if summary:
        print(f"builder:    {' '.join(summary.split())[:120]}")
    if isinstance(report.get("risks"), list):
        for risk in [str(r).strip() for r in report["risks"] if str(r).strip()][:3]:
            print(f"risk:       {risk[:120]}")
    if state.get("human_feedback"):
        print(f"feedback:   queued for next iteration: {state['human_feedback']!r}")
    for key, label in (("latest_agent_result", "agent result"),
                       ("latest_critic_findings", "critic findings")):
        if state.get(key):
            print(f"latest {label}: {state[key]}")
    print(f"next:       {next_step_hint(state)}")
    print("more:       'absoloop watch' is a live terminal dashboard; "
          "'absoloop zcomb' opens the browser Kanban UI; "
          "'absoloop report' shows the full timeline; "
          "'absoloop goal' shows the contract")
    return 0


def extend_mission(target: pathlib.Path, state: dict, engine: str,
                   note: str, iterations: int | None, budget: float | None,
                   hours: float | None, min_iterations: int | None = None,
                   start: bool = True) -> int:
    """Start a follow-on loop run that continues a finished mission's work.

    Archives the previous run's records under .absoloop/runs/<loop_id>/, resets
    state so the runner starts fresh (baseline, counters, budgets), assigns a
    new loop_id, and bakes the previous run's outcome into the regenerated
    goal contract so every iteration knows it is completing earlier work."""
    abs_dir = target / ".absoloop"
    runtime = load_runtime(target)
    if not runtime:
        print(f"error: no readable .absoloop/runtime.json under {target}", file=sys.stderr)
        return 1

    prev_loop_id = runtime.get("loop_id", "previous-loop")
    prev_status = state.get("status", "?")

    # What the last run left behind, for the continuation context.
    summary = ""
    if state.get("latest_agent_result"):
        summary = agent_summary(target, str(state["latest_agent_result"]))

    # Archive the finished run's records; the ledger stays in place so the
    # timeline remains continuous across runs. Clear live report artifacts so
    # the next Report regenerates Evidence and peers for the new loop only.
    archive = abs_dir / "runs" / prev_loop_id
    archive.mkdir(parents=True, exist_ok=True)
    for name in ("state.json", "report.md", "report.html", "goal.md"):
        source = abs_dir / name
        if source.is_file():
            shutil.copy2(source, archive / name)
    (abs_dir / "state.json").unlink()
    for name in ("report.md", "report.html"):
        stale = abs_dir / name
        if stale.is_file():
            stale.unlink()

    new_id = new_loop_id()
    runtime["loop_id"] = new_id
    runtime["continuation"] = {
        "previous_loop_id": prev_loop_id,
        "previous_status": prev_status,
        "iterations": state.get("iteration", 0),
        "cost_usd": float(state.get("cost_usd", 0)),
        "summary": summary,
        "note": note,
    }
    if note.strip():
        # The continuation intent becomes a binding definition-of-done item.
        # Without this, the old (already satisfied) definition of done lets the
        # builder truthfully report done on iteration 1 and the critic pass
        # it — the follow-on run ends after a single iteration of nothing.
        done_items = [str(item) for item in runtime.get("definition_of_done", [])
                      if str(item).strip()]
        done_items.append(
            f"Extension requirement ({new_id}): {note.strip()} — the previous "
            "run's existing result does not satisfy this by itself; this run "
            "must demonstrably advance it with new, inspectable work.")
        runtime["definition_of_done"] = done_items
    if iterations:
        runtime["max_iterations"] = iterations
    if budget:
        runtime["max_cost_usd"] = budget
    if hours:
        runtime["max_wall_seconds"] = int(hours * 3600)
    if min_iterations:
        runtime["min_iterations"] = min_iterations
    elif note.strip():
        # An extension with a focus note is a request for real further work:
        # give it an iteration floor so a first-iteration done claim can't
        # end the run, unless the operator tuned one already.
        runtime.setdefault("min_iterations", 3)
    delivery_mode = (runtime.get("delivery") or {}).get("mode", "local")
    runtime["delivery"] = default_delivery(delivery_mode, new_id)
    model = ""
    if engine:
        model = resolve_engine_model(engine, target,
                                     str(runtime.get("model") or ""))
        runtime["model"] = model

    (abs_dir / "runtime.json").write_text(json.dumps(runtime, indent=2) + "\n",
                                          encoding="utf-8")
    write_goal(target, runtime)

    with (abs_dir / "ledger.jsonl").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps({"ts": time.time(), "type": "extension",
                                 "previous_loop_id": prev_loop_id,
                                 "previous_status": prev_status,
                                 "loop_id": new_id, "note": note},
                                sort_keys=True) + "\n")

    prev_cost = with_tokens(f"${float(state.get('cost_usd', 0)):.2f}",
                            state.get("tokens_total"))
    print(f"extending mission {state.get('mission_id')}: previous run "
          f"{prev_loop_id} ({prev_status}, {state.get('iteration', 0)} iteration(s), "
          f"{prev_cost}) archived to {archive.relative_to(target)}/")
    print(f"new run {new_id}: {runtime.get('max_iterations')} iterations, "
          f"${float(runtime.get('max_cost_usd', 0)):.2f}, "
          f"{int(runtime.get('max_wall_seconds', 0))}s wall clock")
    if note:
        print(f"continuation focus: {note}")
    if not start:
        run_cmd = ("python scripts/absoloop-run" if os.name == "nt"
                   else "./scripts/absoloop-run")
        engine_flag = f" --engine {engine}" if engine else ""
        model_flag = f" --model {model}" if model else ""
        print(f"prepared — launch when ready: {run_cmd}{engine_flag}{model_flag}")
        return 0
    return start_loop(target, engine, model)


def mission_runs(target: pathlib.Path) -> list[dict]:
    """Every loadable mission run under a project, newest first: the current
    run (live .absoloop/state.json) plus each archived run under
    .absoloop/runs/<loop_id>/. Harness one-shot runs live in the same runs/
    directory but carry manifest.json instead of state.json, so they are
    skipped here."""
    abs_dir = target / ".absoloop"
    runtime = load_runtime(target)

    def describe(loop_id: str, state: dict, goal_path: pathlib.Path,
                 current: bool, archive: pathlib.Path | None = None) -> dict:
        objective = ""
        try:
            first = goal_path.read_text(encoding="utf-8").splitlines()[0]
            if first.startswith("# /goal — "):
                objective = first[len("# /goal — "):].strip()
        except (OSError, IndexError):
            pass
        if current and not objective:
            objective = str(runtime.get("objective", "")).strip()
        summary = ""
        if state.get("latest_agent_result"):
            summary = agent_summary(target, str(state["latest_agent_result"]))
        return {
            "loop_id": loop_id,
            "current": current,
            "status": str(state.get("status", "?")),
            "iteration": int(state.get("iteration") or 0),
            "cost_usd": float(state.get("cost_usd") or 0),
            "tokens": state.get("tokens_total"),
            "started_at": state.get("started_at"),
            "objective": objective,
            "summary": summary,
            "archive": archive,
        }

    runs: list[dict] = []
    current_id = str(runtime.get("loop_id", "")).strip()
    state_path = abs_dir / "state.json"
    if state_path.is_file():
        try:
            state = json.loads(state_path.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            state = {}
        if not isinstance(state, dict):
            state = {}
        runs.append(describe(current_id or "current", state,
                             abs_dir / "goal.md", True))
    runs_dir = abs_dir / "runs"
    if runs_dir.is_dir():
        for entry in sorted((p for p in runs_dir.iterdir() if p.is_dir()),
                            key=lambda p: p.name, reverse=True):
            archived_state = entry / "state.json"
            if not archived_state.is_file():
                continue
            if entry.name == current_id and runs and runs[0]["current"]:
                continue  # already listed as the current run
            try:
                state = json.loads(archived_state.read_text(encoding="utf-8"))
            except (OSError, json.JSONDecodeError):
                state = {}
            if not isinstance(state, dict):
                state = {}
            runs.append(describe(entry.name, state, entry / "goal.md", False,
                                 archive=entry))
    return runs


def prepare_previous_run(target: pathlib.Path, run: dict) -> dict | None:
    """Restore an archived run's records (state, report, goal) as the
    mission's current ones so a follow-on extension continues from that run
    instead of the latest one. The run being replaced is archived first, so
    nothing is lost. Returns the loaded state dict, or None on error."""
    abs_dir = target / ".absoloop"
    runtime = load_runtime(target)
    if not runtime:
        print(f"error: no readable .absoloop/runtime.json under {target}",
              file=sys.stderr)
        return None
    archive = run["archive"]
    try:
        state = json.loads((archive / "state.json").read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        print(f"error: unreadable {archive / 'state.json'}: {exc}", file=sys.stderr)
        return None

    current_id = str(runtime.get("loop_id", "")).strip()
    if current_id and current_id != run["loop_id"] \
            and (abs_dir / "state.json").is_file():
        keep = abs_dir / "runs" / current_id
        keep.mkdir(parents=True, exist_ok=True)
        for name in ("state.json", "report.md", "report.html", "goal.md"):
            source = abs_dir / name
            if source.is_file():
                shutil.copy2(source, keep / name)

    for name in ("state.json", "report.md", "report.html", "goal.md"):
        source = archive / name
        if source.is_file():
            shutil.copy2(source, abs_dir / name)

    runtime["loop_id"] = run["loop_id"]
    # The follow-on extends the loaded run's work, so its objective (kept in
    # the archived goal contract) becomes the mission objective again —
    # otherwise the regenerated goal would headline a later run's objective.
    if run["objective"] and run["objective"] != runtime.get("objective"):
        runtime["objective"] = run["objective"]
        runtime["thinking_ladder"] = build_thinking_ladder(
            classify_mission(run["objective"]))
    # Extension requirements added for runs newer than the loaded one belong
    # to work being rolled past — drop them so the loaded run's own contract,
    # not a later run's, is what the follow-on extends. Loop ids embed their
    # creation timestamp, so a plain string compare orders them.
    done_items = []
    for item in runtime.get("definition_of_done", []):
        match = re.match(r"Extension requirement \((loop-[^)]*)\):", str(item))
        if match and match.group(1) > run["loop_id"]:
            continue
        done_items.append(str(item))
    runtime["definition_of_done"] = done_items
    (abs_dir / "runtime.json").write_text(json.dumps(runtime, indent=2) + "\n",
                                          encoding="utf-8")
    with (abs_dir / "ledger.jsonl").open("a", encoding="utf-8") as handle:
        handle.write(json.dumps({"ts": time.time(), "type": "load",
                                 "loop_id": run["loop_id"],
                                 "replaced_loop_id": current_id},
                                sort_keys=True) + "\n")
    return state


def load_command(argv: list[str]) -> int:
    """`absoloop load` — list a project's previous mission runs, pick one,
    and prepare it as the base of a follow-on run with a new objective."""
    parser = argparse.ArgumentParser(
        prog="absoloop load",
        description="Choose a previous mission run and extend it with a new "
                    "objective: lists available runs (current + archived), "
                    "restores the chosen run's records as the mission's "
                    "current base, and starts a follow-on run with fresh "
                    "budgets (like 'absoloop resume --extend', but for any "
                    "earlier run).")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("--run", default="",
                        help="loop id (or unique prefix) to load without the "
                             "interactive picker")
    parser.add_argument("-o", "--objective", "-m", "--note", dest="note",
                        default="",
                        help="what the follow-on run should accomplish")
    parser.add_argument("--engine", choices=list(ENGINES),
                        help="engine for the loop (default: first one found on PATH)")
    parser.add_argument("--iterations", type=int,
                        help="raise max_iterations for the new run")
    parser.add_argument("--budget", type=float,
                        help="raise max_cost_usd for the new run")
    parser.add_argument("--hours", type=float,
                        help="wall-clock budget for the new run, in hours")
    parser.add_argument("--min-iterations", type=int, dest="min_iterations",
                        help="iteration floor — a \"done\" report is not "
                             "accepted before this many iterations")
    parser.add_argument("--no-start", action="store_true",
                        help="prepare the follow-on run but do not launch the loop")
    args = parser.parse_args(argv)

    target = pathlib.Path(args.project).expanduser().resolve()
    if not (target / ".absoloop").is_dir():
        print(f"error: no .absoloop/ under {target} — not an ABSOLOOP project.",
              file=sys.stderr)
        return 1
    runs = mission_runs(target)
    if not runs:
        print(f"no mission runs found under {target}/.absoloop/ — start one "
              "with 'absoloop \"objective\"'.", file=sys.stderr)
        return 1

    ux = _load_briefing()
    interactive = sys.stdin.isatty() and sys.stdout.isatty()
    width = max(56, min(terminal_columns(100), 240))

    def fmt_when(ts) -> str:
        try:
            return time.strftime("%Y-%m-%d %H:%M", time.localtime(float(ts)))
        except (TypeError, ValueError, OSError, OverflowError):
            return "?"

    print(ux.tint("bold", f" PREVIOUS RUNS — {target}"))
    print(ux.tint("dim", " " + "─" * (width - 2)))
    for index, run in enumerate(runs, 1):
        mark = ux.tint("ok", "current") if run["current"] else ux.tint("dim", "archived")
        print(f" {index}. {run['loop_id']}  · {mark} · {run['status']}")
        if run["objective"]:
            print(clip_text(f"      objective : {run['objective']}", width))
        cost = with_tokens(f"${run['cost_usd']:.2f}", run["tokens"])
        started = fmt_when(run["started_at"]) if run["started_at"] else "?"
        print(f"      progress  : {run['iteration']} iteration(s) · {cost} · "
              f"started {started}")
        if run["summary"]:
            print(ux.tint("dim",
                          clip_text(f"      last work : {run['summary']}", width)))
    runs_dir = target / ".absoloop" / "runs"
    if runs_dir.is_dir():
        harness_count = sum(1 for p in runs_dir.iterdir()
                            if p.is_dir() and (p / "manifest.json").is_file())
        if harness_count:
            print(ux.tint("dim", f" (+{harness_count} harness run(s) not shown "
                                 "— 'absoloop inspect' lists them)"))

    chosen = None
    if args.run:
        matches = [r for r in runs if r["loop_id"] == args.run] or \
                  [r for r in runs if r["loop_id"].startswith(args.run)]
        if not matches:
            print(f"error: no run matches {args.run!r}.", file=sys.stderr)
            return 1
        if len(matches) > 1:
            print(f"error: {args.run!r} is ambiguous — matches "
                  + ", ".join(r["loop_id"] for r in matches), file=sys.stderr)
            return 1
        chosen = matches[0]
    elif interactive:
        print()
        while chosen is None:
            answer = ux.ask(f"load which run? (1-{len(runs)}, or loop id; "
                            "q aborts)", "1")
            if answer.lower() in ("q", "quit"):
                print(ux.tint("dim", "Aborted."))
                return 0
            if answer.isdigit() and 1 <= int(answer) <= len(runs):
                chosen = runs[int(answer) - 1]
                continue
            matches = [r for r in runs if r["loop_id"] == answer] or \
                      [r for r in runs if r["loop_id"].startswith(answer)]
            if len(matches) == 1:
                chosen = matches[0]
            else:
                print(ux.tint("warn", f"  pick 1-{len(runs)} or a loop id"))
    else:
        print("\nload a run with: absoloop load --run <loop-id> "
              "-o \"follow-on objective\"")
        return 0

    if chosen["current"] and chosen["status"] == "AWAITING_APPROVAL":
        print("mission is AWAITING_APPROVAL — decide the gate first "
              "('absoloop approve' or 'absoloop reject \"...\"'), then load.",
              file=sys.stderr)
        return 3

    note = args.note.strip()
    if not note:
        if not interactive:
            print("error: pass -o/--objective with what the follow-on run "
                  "should accomplish.", file=sys.stderr)
            return 1
        print()
        print(ux.tint("bold", "What should the follow-on run accomplish?"))
        print(ux.tint("dim", "  one sentence — it extends the loaded run's work"))
        note = ux.ask("  objective")
        while not note:
            note = ux.ask("  objective (required)")

    engine = args.engine or default_engine()
    if engine is None and not args.no_start:
        print("error: no engine available — install 'claude', 'codex', or 'grok'.",
              file=sys.stderr)
        return 1

    if chosen["current"]:
        state = read_state(target)
        if state is None:
            return 1
    else:
        state = prepare_previous_run(target, chosen)
        if state is None:
            return 1
        print(f"loaded run {chosen['loop_id']} ({chosen['status']}) as the "
              "mission's current base")

    return extend_mission(target, state, engine or "", note, args.iterations,
                          args.budget, args.hours, args.min_iterations,
                          start=not args.no_start)


def wall_clock_still_exhausted(target: pathlib.Path, state: dict) -> bool:
    """True when resume would hit wall_clock_budget before any new work."""
    runtime = load_runtime(target) or {}
    try:
        max_wall = float(runtime.get("max_wall_seconds") or 0)
        started = float(state.get("started_at") or 0)
    except (TypeError, ValueError):
        return False
    return bool(started and max_wall and time.time() - started >= max_wall)


def resume_command(argv: list[str], *, force_extend: bool = False) -> int:
    prog = "absoloop extend" if force_extend else "absoloop resume"
    parser = argparse.ArgumentParser(
        prog=prog,
        description=("Start a follow-on run with fresh budgets that continues "
                     "a finished mission's work."
                     if force_extend else
                     "Continue a stopped loop — or, with --extend, start a "
                     "follow-on run that completes a finished mission's work."))
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("--engine", choices=["claude", "codex", "grok"],
                        help="engine for the loop (default: first one found on PATH)")
    if force_extend:
        parser.set_defaults(extend=True)
        note_help = "what the follow-on run should focus on"
        iter_help = "raise max_iterations for the new run"
        budget_help = "raise max_cost_usd for the new run"
        hours_help = "wall-clock budget for the new run, in hours"
        min_iter_help = ("iteration floor — a \"done\" report is not accepted "
                         "before this many iterations")
    else:
        parser.add_argument("--extend", action="store_true",
                            help="start a follow-on run of a finished mission: fresh "
                                 "budgets, new loop id, previous work carried in as context")
        note_help = "with --extend: what the follow-on run should focus on"
        iter_help = "with --extend: raise max_iterations for the new run"
        budget_help = "with --extend: raise max_cost_usd for the new run"
        hours_help = "with --extend: wall-clock budget for the new run, in hours"
        min_iter_help = ("with --extend: iteration floor — a \"done\" report "
                         "is not accepted before this many iterations")
    parser.add_argument("-m", "--note", default="", help=note_help)
    parser.add_argument("--iterations", type=int, help=iter_help)
    parser.add_argument("--budget", type=float, help=budget_help)
    parser.add_argument("--hours", type=float, help=hours_help)
    parser.add_argument("--min-iterations", type=int, dest="min_iterations",
                        help=min_iter_help)
    args = parser.parse_args(argv)
    if force_extend:
        args.extend = True
    target = pathlib.Path(args.project).expanduser().resolve()
    state = read_state(target)
    if state is None:
        return 1
    runner = target / "scripts" / "absoloop-run"
    if not runner.is_file():
        print(f"error: {runner} not found — re-adopt the project with "
              f"'absoloop {target}' first.", file=sys.stderr)
        return 1
    engine = args.engine or default_engine()
    if engine is None:
        print("error: no engine available — install 'claude', 'codex', or 'grok'.",
              file=sys.stderr)
        return 1
    status = state.get("status")
    if args.extend:
        if status == "AWAITING_APPROVAL":
            print("mission is AWAITING_APPROVAL — decide the gate first "
                  "('absoloop approve' or 'absoloop reject \"...\"'), then extend.",
                  file=sys.stderr)
            return 3
        return extend_mission(target, state, engine, args.note,
                              args.iterations, args.budget, args.hours,
                              args.min_iterations)
    if status in ("AWAITING_APPROVAL", "COMPLETED"):
        # The runner's terminal-state guard would refuse anyway; explain here
        # without spawning it.
        print(f"mission {state.get('mission_id')} is {status} — nothing to resume.")
        print(f"next: {next_step_hint(state)}")
        return 0 if status == "COMPLETED" else 3
    if wall_clock_still_exhausted(target, state):
        # Plain resume keeps started_at, so the runner would stop immediately
        # with the same wall_clock_budget reason. Point at extend / raise-cap.
        print("error: wall-clock budget is still exhausted — resume would stop "
              "immediately without running another iteration.", file=sys.stderr)
        print("next: absoloop extend"
              + (f" -C {target}" if args.project not in (".", "") else "")
              + "   # fresh budgets + new loop")
        print("  or: raise max_wall_seconds in .absoloop/runtime.json, "
              "then 'absoloop resume'")
        return 1
    resume_cost = with_tokens(f"${float(state.get('cost_usd', 0)):.2f}",
                              state.get("tokens_total"))
    print(f"resuming mission {state.get('mission_id')} at iteration "
          f"{state.get('iteration')} ({resume_cost} spent, status {status})")
    model = resolve_engine_model(engine, target)
    persist_engine_model(target, engine, model)
    return start_loop(target, engine, model)


def extend_command(argv: list[str]) -> int:
    """`absoloop extend` — alias for `absoloop resume --extend`."""
    return resume_command(argv, force_extend=True)


def gate_command(action: str, argv: list[str]) -> int:
    """Human-gate decisions: `absoloop approve` / `absoloop reject "feedback"`.

    approve marks an AWAITING_APPROVAL mission COMPLETED. reject records your
    English response for the agent — the runner injects it into the next
    iteration's prompt — and re-arms the loop."""
    parser = argparse.ArgumentParser(prog=f"absoloop {action}")
    if action == "reject":
        parser.add_argument("message",
                            help="feedback for the agent (delivered in the next iteration prompt)")
    else:
        parser.add_argument("message", nargs="?", default="",
                            help="optional approval note (recorded in the ledger)")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    args = parser.parse_args(argv)

    target = pathlib.Path(args.project).expanduser().resolve()
    abs_dir = target / ".absoloop"
    state_path = abs_dir / "state.json"
    if not state_path.is_file():
        print(f"error: {state_path} not found — run this inside an ABSOLOOP project "
              "whose loop has run at least once.", file=sys.stderr)
        return 1
    try:
        state = json.loads(state_path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        print(f"error: invalid JSON in {state_path}: {exc}", file=sys.stderr)
        return 1

    def record(event: dict) -> None:
        with (abs_dir / "ledger.jsonl").open("a", encoding="utf-8") as handle:
            handle.write(json.dumps({"ts": time.time(), **event}, sort_keys=True) + "\n")

    def save() -> None:
        checkpoints = abs_dir / "checkpoints"
        checkpoints.mkdir(parents=True, exist_ok=True)
        cp = checkpoints / f"{int(state.get('iteration', 0)):04d}-human-{action}.json"
        state["latest_checkpoint"] = str(cp.relative_to(target))
        body = json.dumps(state, indent=2, sort_keys=True) + "\n"
        cp.write_text(body, encoding="utf-8")
        state_path.write_text(body, encoding="utf-8")

    status = state.get("status")
    if action == "approve":
        if status != "AWAITING_APPROVAL":
            print(f"error: mission status is {status!r}, not AWAITING_APPROVAL — "
                  "nothing to approve.", file=sys.stderr)
            return 1
        state["status"] = "COMPLETED"
        state["stop_reason"] = "human_approved"
        state["human_feedback"] = None
        save()
        record({"type": "human_gate", "decision": "approved", "note": args.message,
                "iteration": state.get("iteration")})
        cost_text = with_tokens(f"${float(state.get('cost_usd', 0)):.2f}",
                                state.get("tokens_total"))
        print(f"mission {state.get('mission_id')} APPROVED and marked COMPLETED "
              f"(iteration {state.get('iteration')}, cost {cost_text}).")
        sync_runner(target)
        runner = target / "scripts" / "absoloop-run"
        if runner.is_file():
            print("Delivering results per the mission's delivery mode...")
            delivered = subprocess.run(
                [sys.executable, str(runner), "--deliver-only"], cwd=target).returncode
            if delivered != 0:
                print("warning: delivery step reported a problem — run "
                      f"'{sys.executable} scripts/absoloop-run --deliver-only' to retry.",
                      file=sys.stderr)
        else:
            print("note: scripts/absoloop-run not found — externalize the result "
                  "yourself (commit / push / PR).")
        print("Full results: absoloop report")
        return 0

    if status not in ("AWAITING_APPROVAL", "BLOCKED", "BUDGET_EXHAUSTED", "REJECTED"):
        print(f"note: mission status is {status!r}; recording feedback anyway.")
    state["status"] = "READY"
    state["stop_reason"] = None
    state["human_feedback"] = args.message
    save()
    record({"type": "human_gate", "decision": "rejected", "feedback": args.message,
            "iteration": state.get("iteration")})
    print("Feedback recorded — the next builder iteration will see it under "
          "'Operator feedback (address this first)'.")
    print("Resume the loop with: absoloop resume")
    return 0


def abort_command(argv: list[str]) -> int:
    """Stop a live mission loop: signal the runner, mark state STOPPED.

    Used by `absoloop abort` and the ZComb Kanban Abort control. Safe to call
    when the loop is already dead — clears a stuck EXECUTING status.
    """
    parser = argparse.ArgumentParser(
        prog="absoloop abort",
        description="Stop a live Absoloop mission loop (SIGTERM the runner tree).")
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="skip confirmation prompt")
    args = parser.parse_args(argv)

    target = pathlib.Path(args.project).expanduser().resolve()
    abs_dir = target / ".absoloop"
    state_path = abs_dir / "state.json"
    if not abs_dir.is_dir():
        print(f"error: {abs_dir} not found — not an Absoloop project.",
              file=sys.stderr)
        return 1

    monitor = load_monitor(target)
    live = monitor_is_live(monitor)
    pid = monitor.get("pid") if isinstance(monitor.get("pid"), int) else None
    state: dict = {}
    if state_path.is_file():
        try:
            loaded = json.loads(state_path.read_text(encoding="utf-8"))
            if isinstance(loaded, dict):
                state = loaded
        except (OSError, json.JSONDecodeError):
            state = {}

    status = str(state.get("status") or monitor.get("status") or "").upper()
    if not live and status not in ("EXECUTING", "FINAL_REVIEW", "RUNNING",
                                   "STARTING"):
        print(f"nothing to abort — mission is not running "
              f"(status {status or 'unknown'}).")
        return 0

    mission = state.get("mission_id") or monitor.get("mission_id") or "?"
    if not args.yes and sys.stdin.isatty():
        prompt = (f"Abort live mission {mission}"
                  + (f" (pid {pid})" if pid and live else "")
                  + "? [y/N] ")
        try:
            answer = input(prompt).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return 1
        if answer not in ("y", "yes"):
            print("Aborted abort.")
            return 1

    signaled = False
    still_alive = False
    # Only signal when the heartbeat proves this pid is *our* live runner.
    # A stale monitor.json pid may have been reused by an unrelated process.
    if live and pid and pid_alive(pid):
        signaled = terminate_mission_pid(pid)
        still_alive = pid_alive(pid)
        if still_alive:
            print(f"warning: runner pid {pid} is still alive after signal",
                  file=sys.stderr)
        elif signaled:
            print(f"signaled runner pid {pid}")
    elif live:
        print("warning: monitor looked live but pid is gone — clearing state",
              file=sys.stderr)
    elif status in ("EXECUTING", "FINAL_REVIEW", "RUNNING", "STARTING"):
        print("clearing stuck run state (loop not live)")

    now = time.time()
    if state:
        state["status"] = "STOPPED"
        state["stop_reason"] = "human_aborted"
        try:
            checkpoints = abs_dir / "checkpoints"
            checkpoints.mkdir(parents=True, exist_ok=True)
            iteration = int(state.get("iteration") or 0)
            cp = checkpoints / f"{iteration:04d}-human-abort.json"
            state["latest_checkpoint"] = str(cp.relative_to(target))
            body = json.dumps(state, indent=2, sort_keys=True) + "\n"
            cp.write_text(body, encoding="utf-8")
            state_path.write_text(body, encoding="utf-8")
        except OSError as exc:
            print(f"warning: could not update state.json: {exc}", file=sys.stderr)

    # Freeze monitor so watch/ZComb immediately show the loop as stopped.
    try:
        tmp = abs_dir / "tmp"
        tmp.mkdir(parents=True, exist_ok=True)
        snapshot = dict(monitor) if monitor else {"schema": 1}
        snapshot.update({
            "status": "STOPPED",
            "phase": "stopped",
            "stop_reason": "human_aborted",
            "live": False,
            "ended_at": now,
            "heartbeat_ts": now - HEARTBEAT_STALE_SECONDS - 1,
        })
        if pid:
            snapshot["pid"] = pid
        mon_path = tmp / "monitor.json"
        mon_path.write_text(json.dumps(snapshot, indent=2, sort_keys=True) + "\n",
                            encoding="utf-8")
    except OSError as exc:
        print(f"warning: could not update monitor.json: {exc}", file=sys.stderr)

    try:
        with (abs_dir / "ledger.jsonl").open("a", encoding="utf-8") as handle:
            handle.write(json.dumps({
                "ts": now,
                "type": "mission_stop",
                "reason": "human_aborted",
                "status": "STOPPED",
                "pid": pid,
                "signaled": signaled,
            }, sort_keys=True) + "\n")
    except OSError:
        pass

    if still_alive:
        print(f"mission {mission} marked STOPPED, but the process did not exit "
              f"— kill pid {pid} manually if it keeps running.", file=sys.stderr)
        return 2

    print(f"mission {mission} aborted (STOPPED · human_aborted).")
    print(f"next: {next_step_hint(state or {'status': 'STOPPED'})}")
    return 0


# Mission history wiped by `absoloop restart` (factory reset). Scaffold
# templates under schemas/ and prompts/ are kept so the project stays usable.
_RESTART_WIPE_FILES = (
    "state.json",
    "runtime.json",
    "goal.md",
    "ledger.jsonl",
    "report.md",
    "report.html",
)
_RESTART_WIPE_DIRS = (
    "checkpoints",
    "tmp",
    "runs",
    "worktrees",
    "zcomb",
)


def factory_reset_project(abs_dir: pathlib.Path) -> list[str]:
    """Remove mission/harness history under `.absoloop/`. Returns labels wiped."""
    wiped: list[str] = []
    for name in _RESTART_WIPE_FILES:
        path = abs_dir / name
        if path.is_file() or path.is_symlink():
            path.unlink(missing_ok=True)
            wiped.append(name)
    for name in _RESTART_WIPE_DIRS:
        path = abs_dir / name
        if path.exists():
            shutil.rmtree(path, ignore_errors=True)
            wiped.append(f"{name}/")
    # Schedule definitions stay; fire history is past absoloop activity.
    history = abs_dir / "schedules" / "history.jsonl"
    if history.is_file():
        history.unlink(missing_ok=True)
        wiped.append("schedules/history.jsonl")
    return wiped


def restart_command(argv: list[str]) -> int:
    """Factory-reset Absoloop in a project: stop any live loop, wipe history.

    Removes past runs, objectives, ledger, reports, checkpoints, harness
    worktrees, and ZComb state under `.absoloop/`. Keeps schemas/, prompts/,
    project schedules (definitions only), and user config under ~/.absoloop/.
    """
    parser = argparse.ArgumentParser(
        prog="absoloop restart",
        description=(
            "Factory-reset Absoloop: wipe all past runs and objectives "
            "for a clean slate (asks for confirmation)."))
    parser.add_argument("-C", "--project", default=".",
                        help="project directory (default: current directory)")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="skip confirmation prompt")
    args = parser.parse_args(argv)

    target = pathlib.Path(args.project).expanduser().resolve()
    abs_dir = target / ".absoloop"
    if not abs_dir.is_dir():
        print(f"error: {abs_dir} not found — not an Absoloop project.",
              file=sys.stderr)
        return 1

    monitor = load_monitor(target)
    live = monitor_is_live(monitor)
    pid = monitor.get("pid") if isinstance(monitor.get("pid"), int) else None

    if not args.yes:
        if not sys.stdin.isatty():
            print("error: factory reset requires confirmation — pass --yes",
                  file=sys.stderr)
            return 1
        extra = ""
        if live and pid:
            extra = f" A live loop (pid {pid}) will be stopped first."
        prompt = (
            f"Factory reset will delete all mission runs, objectives, ledger, "
            f"and reports under {abs_dir}.{extra} Continue? [y/N] "
        )
        try:
            answer = input(prompt).strip().lower()
        except (EOFError, KeyboardInterrupt):
            print()
            return 1
        if answer not in ("y", "yes"):
            print("Restart cancelled.")
            return 1

    if live and pid and pid_alive(pid):
        signaled = terminate_mission_pid(pid)
        if pid_alive(pid):
            print(f"warning: runner pid {pid} is still alive after signal — "
                  f"continuing with wipe", file=sys.stderr)
        elif signaled:
            print(f"signaled runner pid {pid}")
    elif live:
        print("warning: monitor looked live but pid is gone — wiping anyway",
              file=sys.stderr)

    wiped = factory_reset_project(abs_dir)
    if wiped:
        print(f"factory reset complete — removed {len(wiped)} item(s) "
              f"under {abs_dir}:")
        for label in wiped:
            print(f"  · {label}")
    else:
        print(f"factory reset complete — {abs_dir} had no run history to wipe.")
    print('next: absoloop "your new objective"   # clean slate briefing')
    return 0


def start_loop(target: pathlib.Path, engine: str, model: str = "",
               announce: bool = True) -> int:
    sync_runner(target)
    sync_result_schema(target)
    sync_skills(target, engines=(engine,))
    runner = target / "scripts" / "absoloop-run"
    cmd = [sys.executable, str(runner), "--engine", engine]
    if model:
        cmd += ["--model", model]
    if announce:
        # The briefing path already covered this in the prep summary;
        # resume/approve entry points still need the handoff line.
        print(f"  engine {engine} · model {model or 'CLI default'} · "
              f"working tree {target}\n")
    return subprocess.run(cmd, cwd=target).returncode


def _ensure_harness_path() -> None:
    """Put the install that owns this CLI (and ABSOLOOP_HOME) on sys.path."""
    for candidate in (pathlib.Path(__file__).resolve().parent.parent, ABSOLOOP_HOME):
        if (candidate / "absoloop_harness").is_dir():
            if str(candidate) not in sys.path:
                sys.path.insert(0, str(candidate))
            os.environ.setdefault("ABSOLOOP_HOME", str(candidate))
            return
    if str(ABSOLOOP_HOME) not in sys.path:
        sys.path.insert(0, str(ABSOLOOP_HOME))


def _load_harness():
    """The multi-provider harness package lives in the tooling home; import
    it lazily so legacy mission commands never pay for (or break on) it."""
    _ensure_harness_path()
    from absoloop_harness import cli as harness_cli
    return harness_cli


def _load_briefing():
    _ensure_harness_path()
    from absoloop_harness import briefing
    return briefing


def _run_setup(argv: list[str]):
    """Guided first-run wizard. Returns an int exit code, or a
    (code, SetupResult) tuple when callers want the handoff object."""
    _ensure_harness_path()
    from absoloop_harness import setup_wizard
    print_banner(compact=True)
    # Parse flags ourselves so we can return the result object for chaining.
    yes = "-y" in argv or "--yes" in argv
    force = "--force" in argv
    if "--check" in argv:
        return setup_wizard.setup_command(["--check"])
    if "--reset" in argv:
        return setup_wizard.setup_command(["--reset"])
    result = setup_wizard.run_wizard(yes=yes, force=force)
    if result.aborted:
        return 1
    if not result.completed:
        return 1
    return (0 if result.providers_ready or yes else 2, result)


def scaffold_mission(target: pathlib.Path, objective: str,
                     delivery_mode: str,
                     model: str = "") -> tuple[dict, pathlib.Path]:
    """Create/adopt project files and write runtime + /goal. Returns
    (config, goal_path)."""
    scripts = target / "scripts"
    scripts.mkdir(parents=True, exist_ok=True)
    sync_runner(target)
    sync_result_schema(target)
    sync_skills(target)
    for tmpl in ("absoloop-init",):
        src = TEMPLATES / tmpl
        dest = scripts / tmpl
        if not src.is_file():
            continue
        if dest.exists():
            continue
        shutil.copy(src, dest)
        if os.name != "nt":
            os.chmod(dest, 0o755)

    if shutil.which("git"):
        inside = subprocess.run(
            ["git", "-C", str(target), "rev-parse", "--is-inside-work-tree"],
            capture_output=True, text=True)
        if inside.returncode != 0:
            subprocess.run(["git", "init", "-q", str(target)], check=False)
            prep_note("git: initialized a new repository")

    abs_dir = target / ".absoloop"
    legacy_dir = target / ".absolution"
    if legacy_dir.is_dir() and not abs_dir.exists():
        legacy_dir.rename(abs_dir)
        prep_note("migrated legacy .absolution/ config to .absoloop/")
    for legacy in ("absolution-run", "absolution-init"):
        if (scripts / legacy).exists():
            prep_note(f"note: scripts/{legacy} is from the old ABSOLUTION name and "
                      f"can be deleted; {legacy.replace('absolution', 'absoloop')} "
                      "replaces it.")

    runtime_path = abs_dir / "runtime.json"
    existing_config = None
    if runtime_path.is_file():
        try:
            existing_config = json.loads(runtime_path.read_text(encoding="utf-8"))
        except (json.JSONDecodeError, OSError):
            print(f"warning: {runtime_path} is unreadable — rebuilding it.",
                  file=sys.stderr)

    for sub in ("tmp", "checkpoints", "schemas", "prompts"):
        (abs_dir / sub).mkdir(parents=True, exist_ok=True)
    sync_result_schema(target)
    critic_path = abs_dir / "prompts" / "critic-final-review.md"
    if not critic_path.exists():
        critic_path.write_text(CRITIC_PROMPT, encoding="utf-8")

    if existing_config:
        previous_objective = str(existing_config.get("objective", "")).strip()
        existing_config["objective"] = objective
        if (objective != previous_objective
                or validate_thinking_ladder(existing_config.get("thinking_ladder"))):
            existing_config["thinking_ladder"] = build_thinking_ladder(
                classify_mission(objective))
        existing_config.pop("verify_command", None)
        critic_path_cfg = str(existing_config.get("critic_prompt_path", ""))
        if critic_path_cfg.startswith(".absolution/"):
            existing_config["critic_prompt_path"] = (
                ".absoloop/" + critic_path_cfg[len(".absolution/"):])
        existing_config.setdefault("loop_id", new_loop_id())
        existing_config.setdefault("goal_path", ".absoloop/goal.md")
        existing_config["delivery"] = default_delivery(
            delivery_mode, existing_config["loop_id"])
        if model:
            existing_config["model"] = model
        config = existing_config
    else:
        config = runtime_config(objective, new_loop_id(), delivery_mode,
                                model=model)

    runtime_path.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")
    goal_path = write_goal(target, config)

    gitignore = target / ".gitignore"
    ignore_line = ".absoloop/tmp/"
    existing_ignores = gitignore.read_text(encoding="utf-8") if gitignore.is_file() else ""
    if ignore_line not in existing_ignores.splitlines():
        gitignore.write_text(
            existing_ignores
            + ("" if existing_ignores.endswith("\n") or not existing_ignores else "\n")
            + ignore_line + "\n", encoding="utf-8")
    return config, goal_path


def _resolve_target(name: str) -> pathlib.Path:
    return (pathlib.Path.cwd() / pathlib.Path(name).expanduser()).resolve()


def _engine_labels() -> dict:
    labels = {}
    for engine in ENGINES:
        labels[engine] = ("✓ on PATH" if shutil.which(engine)
                          else "✗ not found")
    return labels


def main(argv: list[str]) -> int:
    # Lightweight peel of --zcomb before any subcommand dispatch.
    want_zcomb = False
    if "--zcomb" in argv:
        _ensure_harness_path()
        from absoloop_harness import zcomb as zcomb_mod
        argv, want_zcomb = zcomb_mod.extract_zcomb_flag(argv)
    else:
        zcomb_mod = None  # type: ignore[assignment]

    if argv and argv[0] == "zcomb":
        _ensure_harness_path()
        from absoloop_harness import zcomb as zcomb_mod
        return zcomb_mod.zcomb_command(argv[1:])
    # ZComb-only flags without a mission → dashboard (e.g. --port / -C / --once).
    # Bare `absoloop --zcomb` falls through to the same briefing/launch as
    # `absoloop`, then opens the Kanban UI when the loop starts.
    if want_zcomb and zcomb_mod is not None and argv and argv[0].startswith("-") \
            and not any(a in ("-o", "--objective", "--engine", "--start", "-y",
                              "--yes", "--no-start", "-d", "--deliver")
                        for a in argv):
        # e.g. absoloop --zcomb -C ./proj --port 3141
        return zcomb_mod.zcomb_command(argv)

    # `absoloop new` is the standard briefing flow under an explicit name —
    # peel the word and fall through to the same parser as bare `absoloop`.
    if argv and argv[0] == "new":
        argv = argv[1:]

    if argv and argv[0] in ("approve", "reject"):
        return gate_command(argv[0], argv[1:])
    if argv and argv[0] in ("abort", "stop"):
        return abort_command(argv[1:])
    if argv and argv[0] == "restart":
        return restart_command(argv[1:])
    if argv and argv[0] == "load":
        return load_command(argv[1:])
    if argv and argv[0] == "status":
        return status_command(argv[1:])
    if argv and argv[0] == "watch":
        return watch_command(argv[1:])
    if argv and argv[0] == "report":
        return report_command(argv[1:])
    if argv and argv[0] == "goal":
        return goal_command(argv[1:])
    if argv and argv[0] == "resume":
        harness = _load_harness()
        outcome = harness.harness_resume_command(argv[1:])
        if outcome is not None:
            return outcome
        return resume_command(argv[1:])
    if argv and argv[0] == "extend":
        return extend_command(argv[1:])
    if argv and argv[0] in ("setup", "wizard", "onboard", "getting-started"):
        outcome = _run_setup(argv[1:])
        if isinstance(outcome, tuple):
            code, result = outcome
            yes = "-y" in argv[1:] or "--yes" in argv[1:]
            if not yes and result.completed and result.providers_ready:
                _ensure_harness_path()
                from absoloop_harness import setup_wizard as setup_ux
                objective = setup_ux.offer_first_mission(False, result)
                if objective:
                    return main([objective] + (["--zcomb"] if want_zcomb else []))
            return code
        return outcome
    if argv and argv[0] in ("doctor", "providers", "run", "build", "review",
                            "cancel", "inspect", "apply", "config"):
        return _load_harness().dispatch(argv[0], argv[1:])
    if argv and argv[0] in ("shortcuts", "shortcut", "do"):
        _ensure_harness_path()
        from absoloop_harness import shortcuts as sc
        if argv[0] == "do":
            return sc.do_command(argv[1:])
        return sc.shortcuts_command(argv[1:])
    if argv and argv[0] in ("schedule", "schedules"):
        _ensure_harness_path()
        from absoloop_harness import schedule as sched
        return sched.schedule_command(argv[1:])

    parser = BannerParser(
        prog="absoloop",
        description="Absoloop — bounded AI repair loops. Briefing, then launch.",
        epilog=EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument(
        "mission", nargs="?",
        help="project name, '.', or a quoted objective "
             "(e.g. absoloop \"Make all tests pass\")")
    parser.add_argument("-o", "--objective", help="mission objective (one sentence)")
    parser.add_argument("-d", "--deliver", choices=sorted(DELIVERY_MODES),
                        help="where accepted work lands (default: local)")
    parser.add_argument("--engine", choices=list(ENGINES),
                        help="engine for the loop")
    parser.add_argument("--model", default=None,
                        help="model id/alias for the engine "
                             "(default: best available for that engine)")
    parser.add_argument("--start", action="store_true",
                        help="launch after scaffolding (default on TTY after review)")
    parser.add_argument("-y", "--yes", action="store_true",
                        help="skip the interactive briefing review and launch")
    parser.add_argument("--no-start", action="store_true",
                        help="scaffold only; do not launch the loop")
    parser.add_argument(
        "--zcomb", action="store_true",
        help="same briefing/launch as absoloop, then open ZComb Kanban "
             "(Node.js 18+; dashboard-only: absoloop zcomb)")
    args = parser.parse_args(argv)
    # Flag may arrive via argparse (after extract) only if someone passes it
    # again; prefer the early extract.
    want_zcomb = want_zcomb or bool(getattr(args, "zcomb", False))

    # Full infinity + wordmark — compact one-liner is too small on briefing /
    # --zcomb entry. Setup wizard keeps the compact mark.
    print_banner(compact=False)
    ux = _load_briefing()

    # First-time TTY users with no objective → offer the setup wizard.
    _ensure_harness_path()
    from absoloop_harness import setup_wizard as setup_ux
    bare = not (args.mission or args.objective)
    if bare and setup_ux.should_offer_first_run() and not args.yes:
        gate = setup_ux.first_run_gate()
        if gate == "quit":
            return 0
        if gate == "setup":
            outcome = _run_setup([])
            if isinstance(outcome, tuple):
                code, result = outcome
                objective = setup_ux.offer_first_mission(False, result)
                if objective:
                    args.objective = objective
                else:
                    return code
            else:
                return outcome

    runner_template = TEMPLATES / "absoloop-run"
    if not runner_template.is_file():
        print(f"error: missing template {runner_template}", file=sys.stderr)
        return 1

    available = tuple(e for e in ENGINES if shutil.which(e))
    print(ux.opening_line(available))
    print()

    # --- parse positional: name vs free-text objective -----------------------
    positional = (args.mission or "").strip()
    objective = (args.objective or "").strip()
    name = ""
    if positional:
        if ux.looks_like_objective(positional) and not objective:
            objective = positional
        else:
            name = positional

    # Peek at an existing runtime for defaults when adopting a named path.
    peek_target = _resolve_target(name or ".")
    existing_objective = ""
    existing_delivery = ""
    if (peek_target / ".absoloop" / "runtime.json").is_file():
        try:
            peek = json.loads(
                (peek_target / ".absoloop" / "runtime.json").read_text(encoding="utf-8"))
            existing_objective = str(peek.get("objective", "")).strip()
            existing_delivery = str((peek.get("delivery") or {}).get("mode", ""))
        except (json.JSONDecodeError, OSError):
            pass

    objective = objective or existing_objective
    delivery = args.deliver or existing_delivery or "local"
    if delivery not in DELIVERY_MODES:
        delivery = "local"
    engine = args.engine or (available[0] if available else ENGINES[0])

    _ensure_harness_path()
    from absoloop_harness.models import resolve_model
    model = resolve_model(engine, args.model or "")

    # Default project: adopt cwd (fewest steps). Rename from the briefing card.
    if not name:
        name = "." if not objective else (
            "." if peek_target.is_dir() else ux.slug_from_objective(objective))

    interactive = sys.stdin.isatty() and sys.stdout.isatty()

    # Only ask for the one thing we cannot invent: the objective.
    if not objective:
        if not interactive:
            print("error: pass -o/--objective or a quoted mission string.",
                  file=sys.stderr)
            return 1
        print(ux.tint("bold", "What's the mission?"))
        print(ux.tint("dim", "  one sentence — what should be true when we stop?"))
        objective = ux.ask("  objective")
        while not objective:
            objective = ux.ask("  objective (required)")

    if not re.fullmatch(r"[A-Za-z0-9._-]+", name) and name != "." \
            and not pathlib.Path(name).expanduser().is_dir():
        print("error: project name must be letters/numbers/._- or '.'",
              file=sys.stderr)
        return 1

    target = _resolve_target(name)
    if target.exists() and not target.is_dir():
        print(f"error: {target} exists and is not a directory.", file=sys.stderr)
        return 1

    brief = ux.Briefing(
        target=str(target),
        # Keep '.' as '.' so post-review path resolution adopts cwd —
        # never rewrites to cwd/<basename>.
        target_name=name or ".",
        adopting=target.is_dir(),
        objective=objective,
        delivery=delivery,
        engine=engine,
        model=model,
        kinds=classify_mission(objective) or ["general"],
        engines_available=available,
    )

    def preview_goal(b) -> None:
        from_text = generate_goal_markdown(
            runtime_config(b.objective, "preview", b.delivery, model=b.model))
        print()
        print(ux.tint("dim", "  ── /goal preview ──"))
        for line in from_text.splitlines()[:40]:
            print("  " + line)
        if from_text.count("\n") > 40:
            print(ux.tint("dim", "  …"))
        print()

    if interactive and not args.yes and not args.no_start:
        confirmed = ux.review_loop(
            brief,
            engines=ENGINES,
            engine_labels=_engine_labels(),
            deliveries=("local", "git", "out"),
            classify=classify_mission,
            preview_goal=preview_goal,
        )
        if confirmed is None:
            return 1
        brief = confirmed
    else:
        print(ux.render_card(brief))

    # Resolve project path from the (possibly renamed) briefing.
    if brief.target_name in (".",):
        target = pathlib.Path.cwd().resolve()
    else:
        target = _resolve_target(brief.target_name)
    brief = __import__("dataclasses").replace(
        brief, target=str(target), adopting=target.is_dir())

    if target.exists() and not target.is_dir():
        print(f"error: {target} exists and is not a directory.", file=sys.stderr)
        return 1

    model = resolve_model(brief.engine, brief.model)
    brief = __import__("dataclasses").replace(brief, model=model)
    launch = not args.no_start
    with collect_prep_notes() as prep_notes:
        _config, goal_path = scaffold_mission(
            target, brief.objective, brief.delivery, model=brief.model)
    ux.prep_summary(brief, str(goal_path.relative_to(target)),
                    notes=prep_notes, launching=launch)

    if not launch:
        run_cmd = ("python scripts/absoloop-run" if os.name == "nt"
                   else "./scripts/absoloop-run")
        steps = ([] if target == pathlib.Path.cwd().resolve()
                 else [f"cd {os.path.relpath(target)}"])
        model_flag = f" --model {brief.model}" if brief.model else ""
        steps.append(f"{run_cmd} --engine {brief.engine}{model_flag}")
        print(ux.tint("dim", "  Scaffold ready. Launch when you are:"))
        print("  " + "\n  ".join(steps))
        return 0

    if brief.engine not in available:
        print(f"error: engine '{brief.engine}' not on PATH — "
              f"install it or re-run and pick another (e).", file=sys.stderr)
        return 1
    if want_zcomb:
        if zcomb_mod is None:
            _ensure_harness_path()
            from absoloop_harness import zcomb as zcomb_mod
        zcomb_mod.spawn_background(target)
    return start_loop(target, brief.engine, brief.model, announce=False)


if __name__ == "__main__":
    sys.exit(main(sys.argv[1:]))
